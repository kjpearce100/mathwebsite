matrix([[3, 2, -1, -15],[5, 3, 2, 0],[3, 1, 3, 11],[-6,4,2,15]]);" }}}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 21 "C := mulrow(C,1,1/3);" }}}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 22 "C := addrow(C,1,2,-5);" }}}
