{PARA 0 "> " 0 "" {MPLTEXT 1 0 22 "B := addrow(B,1,2,-5);" }}}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 22 "B := addrow(B,1,3,-3);" }}}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 20 "B := swaprow(B,2,3);" }}}{EXCHG 
