{SECT 0 {PARA 256 "" 0 "" {TEXT 263 23 "Algebraic Manipulations" }}
{PARA 0 "" 0 "" {TEXT 306 39 "Larry Moffett  Math 5364  March 31,2003
" }}{PARA 0 "" 0 "" {TEXT -1 179 "Save your current worksheet as work0
2-yourlastname.mws.  Remember to save frequently to avoid losing data \+
in case that the system would shut down in the middle of a work sessio
n! " }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 104 "I
n the text mode (click on the cap T button) place your name(s) and dat
e at the top of your worksheet.  " }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}
{PARA 0 "" 0 "" {TEXT -1 531 "1.  Basic Manipulations.  We can use Map
le to manipulate algebraic expression as well as to perform arithmetic
 calculations.  The intent is to learn some basic Maple syntax, while \+
observing some of the neat features of a Computer Algebra System (CAS)
.  We will also review some basic concepts from arithmetic.   Perform \+
the following calculations with Maple.  As you do these exercises ente
r notes and comments onto your worksheet in text mode.  Note the usage
 of operators +,-,*,/,^,!  and the usage or non-usage of parentheses. \+
 " }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 60 "Let \+
the following variables represent algebraic expressions:" }}{PARA 0 "
" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 6 "1.    " }{XPPEDIT 
19 1 "f := x^3-x^2-2*x" "6#>%\"fG,(*$%\"xG\"\"$\"\"\"*$F'\"\"#!\"\"*&F
+F)F'F)F," }{TEXT -1 11 "      2.   " }{XPPEDIT 19 1 "g := 6*x^3+11*x^
2+6*x+1" "6#>%\"gG,**&\"\"'\"\"\"*$%\"xG\"\"$F(F(*&\"#6F(*$F*\"\"#F(F(
*&F'F(F*F(F(F(F(" }{TEXT -1 22 "                 3.   " }{XPPEDIT 19 
1 "h := x^3-5*x+x^2-5;" "6#>%\"hG,**$%\"xG\"\"$\"\"\"*&\"\"&F)F'F)!\"
\"*$F'\"\"#F)F+F," }{TEXT -1 19 "                   " }}{PARA 0 "" 0 "
" {TEXT -1 6 "4.    " }{XPPEDIT 19 1 "F := x^4-1" "6#>%\"FG,&*$%\"xG\"
\"%\"\"\"F)!\"\"" }{TEXT -1 22 "                5.    " }{XPPEDIT 19 
1 "G := 3*x^4+4*x^3-2*x^2+x-6;" "6#>%\"GG,,*&\"\"$\"\"\"*$%\"xG\"\"%F(
F(*&F+F(*$F*F'F(F(*&\"\"#F(*$F*F/F(!\"\"F*F(\"\"'F1" }{TEXT -1 14 "   \+
      6.   " }{XPPEDIT 19 1 "H := 2*x^2+3*x-2" "6#>%\"HG,(*&\"\"#\"\"
\"*$%\"xGF'F(F(*&\"\"$F(F*F(F(F'!\"\"" }{TEXT -1 24 "                 \+
       " }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 
49 "Calcuate the following (each on a separate line):" }}{PARA 0 "" 0 
"" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 123 "a.   f*g             \+
          b.   g*(h-f)                  c.   f^3                 d.  (
f + g)*(f - h) + (f - g)*(f + h)" }}{PARA 0 "" 0 "" {TEXT -1 141 "e.  \+
F*H/G                  f.   (F/H)/G                 g.  F/(H/G)       \+
    h.    F/H*G                                        i.   F/(H*G)" }
}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{EXCHG {PARA 11 "" 1 "" {TEXT -1 0 "
" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 17 "f := x^3-x^2-2*x;" }}
