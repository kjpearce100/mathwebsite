x^2+2;   \n    " }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#p2G,&*$)%\"xG\"
\"#\"\"\"F*F)F*" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 11 "solve(p2
