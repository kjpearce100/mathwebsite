0 18 "for n from 1 to 10" }}{PARA 0 "> " 0 "" {MPLTEXT 1 0 34 "do seq(
coeff((a+1)^n,a,i),i=0..n);" }}{PARA 0 "> " 0 "" {MPLTEXT 1 0 3 "od;" 
