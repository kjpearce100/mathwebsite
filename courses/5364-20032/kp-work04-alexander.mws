\"zGF*F+!\"\"" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 49 "plot3d(q,x
=-100..100,z=-100..100,numpoints=1000);" }}{PARA 13 "" 1 "" {GLPLOT3D 
