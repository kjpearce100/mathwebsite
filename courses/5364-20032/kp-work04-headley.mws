{SECT 0 {PARA 258 "" 0 "" {TEXT -1 17 "Catherine Headley" }}{PARA 0 "
" 0 "" {TEXT -1 11 "May 5, 2003" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}
{PARA 256 "" 0 "" {TEXT 256 34 "Introduction to Graphing Functions" }}
{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 179 "Save you
r current worksheet as work04-yourlastname.mws.  Remember to save freq
uently to avoid losing data in case that the system would shut down in
 the middle of a work session! " }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}
{PARA 0 "" 0 "" {TEXT -1 104 "In the text mode (click on the cap T but
ton) place your name(s) and date at the top of your worksheet.  " }}
{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 
0 "" 0 "" {TEXT -1 31 "1.  Graphing functions and the " }{TEXT 257 4 "
plot" }{TEXT -1 89 " command.  The Maple command for plotting the grap
h of an explicitly defined function is:" }}{PARA 0 "" 0 "" {TEXT -1 0 
"" }}{PARA 0 "" 0 "" {TEXT -1 5 "     " }{TEXT 258 0 "" }{TEXT 259 4 "
plot" }{TEXT 260 0 "" }{TEXT -1 2 "( " }{TEXT 261 4 "expr" }{TEXT -1 
2 ", " }{TEXT 266 1 "x" }{TEXT -1 20 "=range [, options]);" }}{PARA 0 
"" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 6 "where " }{TEXT 
262 4 "expr" }{TEXT 267 1 " " }{TEXT -1 24 "is a symbolic expression" 
}{TEXT 264 1 " " }{TEXT -1 48 "which represents the function to be plo
tted and " }{TEXT 263 1 "x" }{TEXT -1 38 " is the independent variable
 used in  " }{TEXT 265 4 "expr" }{TEXT -1 25 "  to define the function
." }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 81 "Seve
ral options exist to change way the plot will appear.  These options i
nclude:" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 
126 "            y=range                       this allows the user to
 specifiy the range of output values which Maple will display" }}
{PARA 0 "" 0 "" {TEXT -1 113 "            thickness=value           th
is controls the thickness of the plotted curve.  value = 1, 2, 3, 4, o
r 5" }}{PARA 0 "" 0 "" {TEXT -1 119 "            color=value          \+
       this sets the color of the plotted curve.  value = red, green, \+
blue, cyan, etc." }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" 
{TEXT -1 160 "For each of the following functions provide a plot to re
present the graph the function.  Choose a range that will optimally re
present the features of the graph." }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}
{PARA 0 "" 0 "" {TEXT -1 16 "a.    y = 3x - 1" }}{PARA 0 "" 0 "" 
{TEXT -1 6 "b.    " }{XPPEDIT 18 0 "y = 6*x^2+24*x-8;" "6#/%\"yG,(*&\"
\"'\"\"\"*$%\"xG\"\"#F(F(*&\"#CF(F*F(F(\"\")!\"\"" }}{PARA 0 "" 0 "" 
{TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 5 "c.   " }{XPPEDIT 18 0 "y =
 ((1+x)/(1-x))^(1/2);" "6#/%\"yG)*&,&\"\"\"F(%\"xGF(F(,&F(F(F)!\"\"F+*
&F(F(\"\"#F+" }{TEXT -1 1 " " }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 
0 "" 0 "" {TEXT -1 4 "d.  " }{XPPEDIT 18 0 "y = exp(-x^2)/(1+x^2);" "6
#/%\"yG*&-%$expG6#,$*$%\"xG\"\"#!\"\"\"\"\",&F.F.*$F+F,F.F-" }}{PARA 
0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 88 "f1:=3*x-1;\nf2:=6*x^2+24*x-8;\nf3:=
(((1+x)/(1-x))^(1/2));\nf4:=(((exp(1)^(-x^2))/(1+x^2)));" }}{PARA 11 "
" 1 "" {XPPMATH 20 "6#>%#f1G,&*&\"\"$\"\"\"%\"xGF(F(F(!\"\"" }}{PARA 
11 "" 1 "" {XPPMATH 20 "6#>%#f2G,(*&\"\"'\"\"\")%\"xG\"\"#F(F(*&\"#CF(
F*F(F(\"\")!\"\"" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#f3G*$*&,&\"\"\"
F(%\"xGF(F(,&F(F(F)!\"\"F+#F(\"\"#" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#
>%#f4G*&)-%$expG6#\"\"\",$*$)%\"xG\"\"#F*!\"\"F*,&F*F*F,F*F0" }}}
