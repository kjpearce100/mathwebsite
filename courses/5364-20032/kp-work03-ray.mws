{MPLTEXT 1 0 31 "seq(coeff((a+1)^7,a,i),i=0..7);" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6(\"\"\"\"\"(\"#@\"#NF&F%" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 0 "" }}}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 0 "> " 0 "
