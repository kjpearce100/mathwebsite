#8F)-F&6#\"#<F)" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 16 "ifactor(
38*865);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#**-%!G6#\"\"#\"\"\"-F%6#\"
\"&F(-F%6#\"#>F(-F%6#\"$t\"F(" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 
0 13 "ifactor(10!);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#**)-%!G6#\"\"#
\"\")\"\"\")-F&6#\"\"$\"\"%F*)-F&6#\"\"&F(F*-F&6#\"\"(F*" }}}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 18 "ifactor(384*8650);" }}{PARA 11 "" 
1 "" {XPPMATH 20 "6#**)-%!G6#\"\"#\"\")\"\"\"-F&6#\"\"$F*)-F&6#\"\"&F(
F*-F&6#\"$t\"F*" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 15 "ifactor(
10!+1);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#*&-%!G6#\"#6\"\"\"-F%6#\"'
\"*)H$F(" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 19 "ifactor(4029805
68);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#**)-%!G6#\"\"#\"\"$\"\"\"-F&6#
F)F*-F&6#\"$P\"F*-F&6#\"'hD7F*" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 
1 0 0 "" }}}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 
384 "7.  Greatest Common Divisors and Least Common Multiple (and the F
undamental Theorem of Arithmetic).  Maple can compute for a pair of in
tegers (a,b) both the greatest common divisor of  (a,b) and the least \+
common multiple of (a,b) easily.  The commands for doing so are gcd(a,
b) and lcm(a,b), respectively.  For each of the following pairs (a,b) \+
find both the gcd(a,b) and the lcm(a,b)" }}{PARA 0 "" 0 "" {TEXT -1 0 
"" }}{PARA 0 "" 0 "" {TEXT -1 105 "a.  74,148           b.  201, 1001 \+
        c.  202, 1002     d.  2432902008176640000,41758540970065920000
" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 
