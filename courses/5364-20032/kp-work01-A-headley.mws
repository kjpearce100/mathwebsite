F*\"\"\"-F(6#\"\"$F+" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 33 "lcm
(144,84)=ifactor(lcm(144,84));" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#/\"%
