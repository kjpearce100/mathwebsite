x-y^2)" "6#-%$cosG6#,&*&\"\"#\"\"\"%\"xGF)F)*$%\"yGF(!\"\"" }}{PARA 0 
"" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 4 "b.  " }{XPPEDIT 
