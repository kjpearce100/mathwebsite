0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 4 "c.  " }{XPPEDIT 
18 0 "z = x^2-y^2;" "6#/%\"zG,&*$%\"xG\"\"#\"\"\"*$%\"yGF(!\"\"" }}
{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 4 "d.  " }
