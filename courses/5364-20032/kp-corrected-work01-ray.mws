{XPPMATH 20 "6#\"$[\"" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 14 "gc
d(201,1001);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#\"\"\"" }}}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 14 "lcm(201,1001);" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#\"',7?" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 14 "gc
d(202,1002);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#\"\"#" }}}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 14 "lcm(202,1002);" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#\"'-75" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 46 "gc
d(2432902008176640000,41758540970065920000);" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#\"1++ofV?Kv" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 
46 "lcm(2432902008176640000,41758540970065920000);" }}{PARA 11 "" 1 "
" {XPPMATH 20 "6#\"8++;#HJLt3!)[8" }}}{PARA 0 "" 0 "" {TEXT -1 74 "For
 the pair of numbers 144 and 84 execute the following command sequence
:" }}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 33 "144=ifactor(144);\n84=i
factor(84);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#/\"$W\"*&)-%!G6#\"\"#\"
\"%\"\"\")-F(6#\"\"$F*F," }}{PARA 11 "" 1 "" {XPPMATH 20 "6#/\"#%)*()-
%!G6#\"\"#F*\"\"\"-F(6#\"\"$F+-F(6#\"\"(F+" }}}{EXCHG {PARA 0 "> " 0 "
" {MPLTEXT 1 0 23 "144*84=ifactor(144*84);" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#/\"&'47*()-%!G6#\"\"#\"\"'\"\"\")-F(6#\"\"$F0F,-F(6#\"
\"(F," }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 33 "gcd(144,84)=ifacto
r(gcd(144,84));" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#/\"#7*&)-%!G6#\"\"#
F*\"\"\"-F(6#\"\"$F+" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 33 "lcm
(144,84)=ifactor(lcm(144,84));" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#/\"%
35*()-%!G6#\"\"#\"\"%\"\"\")-F(6#\"\"$F*F,-F(6#\"\"(F," }}}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 57 "lcm(144,84)*gcd(144,84)=ifactor(lcm
(144,84)*gcd(144,84));" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#/\"&'47*()-%
!G6#\"\"#\"\"'\"\"\")-F(6#\"\"$F0F,-F(6#\"\"(F," }}}{PARA 0 "" 0 "" 
{TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 82 "For the pair of numbers 2
744280 and 267300 execute the following command sequence:" }}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 49 "2744280=ifactor(2744280);\n267300=i
factor(267300);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#/\"(!GWF*,)-%!G6#\"
\"#\"\"$\"\"\")-F(6#F+\"\"%F,-F(6#\"\"&F,-F(6#\"\"(F,)-F(6#\"#6F*F," }
}{PARA 11 "" 1 "" {XPPMATH 20 "6#/\"'+tE**)-%!G6#\"\"#F*\"\"\")-F(6#\"
\"$\"\"&F+)-F(6#F0F*F+-F(6#\"#6F+" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 39 "2744280*267300=ifactor(2744280*267300);" }}{PARA 11 "
" 1 "" {XPPMATH 20 "6#/\"-+S/YNt*,)-%!G6#\"\"#\"\"&\"\"\")-F(6#\"\"$\"
\"*F,)-F(6#F+F0F,-F(6#\"\"(F,)-F(6#\"#6F0F," }}}{EXCHG {PARA 0 "> " 0 
"" {MPLTEXT 1 0 49 "gcd(2744280,267300)=ifactor(gcd(2744280,267300));
" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#/\"&?y\"**)-%!G6#\"\"#F*\"\"\")-F(
6#\"\"$\"\"%F+-F(6#\"\"&F+-F(6#\"#6F+" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 49 "lcm(2744280,267300)=ifactor(lcm(2744280,267300));" }}
{PARA 11 "" 1 "" {XPPMATH 20 "6#/\")+U;T*,)-%!G6#\"\"#\"\"$\"\"\")-F(6
#F+\"\"&F,)-F(6#F0F*F,-F(6#\"\"(F,)-F(6#\"#6F*F," }}}{EXCHG {PARA 0 ">
 " 0 "" {MPLTEXT 1 0 89 "lcm(2744280,267300)*gcd(2744280,267300)=ifact
or(lcm(2744280,267300)*gcd(2744280,267300));" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#/\"-+S/YNt*,)-%!G6#\"\"#\"\"&\"\"\")-F(6#\"\"$\"\"*F,)-
F(6#F+F0F,-F(6#\"\"(F,)-F(6#\"#6F0F," }}}{PARA 0 "" 0 "" {TEXT -1 0 "
" }}{PARA 0 "" 0 "" {TEXT -1 11 "You assign " }{TEXT 272 2 "x " }
{TEXT -1 4 "and " }{TEXT 273 1 "y" }{TEXT -1 88 " to be any pair of nu
mbers (positive integers).  Execute the following command sequence:" }
}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 14 "x :=3;\ny := 4;" }}{PARA 
11 "" 1 "" {XPPMATH 20 "6#>%\"xG\"\"$" }}{PARA 11 "" 1 "" {XPPMATH 20 
"6#>%\"yG\"\"%" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 27 "x=ifactor
(x);\ny=ifactor(y);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#/\"\"$-%!G6#F$
" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#/\"\"%*$)-%!G6#\"\"#F*\"\"\"" }}}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 17 "x*y=ifactor(x*y);" }}{PARA 
11 "" 1 "" {XPPMATH 20 "6#/\"#7*&)-%!G6#\"\"#F*\"\"\"-F(6#\"\"$F+" }}}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 27 "gcd(x,y)=ifactor(gcd(x,y));
" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#/\"\"\"F$" }}}{EXCHG {PARA 0 "> " 
0 "" {MPLTEXT 1 0 27 "lcm(x,y)=ifactor(lcm(x,y));" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#/\"#7*&)-%!G6#\"\"#F*\"\"\"-F(6#\"\"$F+" }}}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 45 "lcm(x,y)*gcd(x,y)=ifactor(lcm(x,y)*
gcd(x,y));" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#/\"#7*&)-%!G6#\"\"#F*\"
\"\"-F(6#\"\"$F+" }}}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" 
{TEXT -1 0 "" }{TEXT 271 97 "What was the common theme of the above th
ree sets of calculations for different pairs of numbers?" }}{PARA 0 "
" 0 "" {TEXT -1 26 "That x*y=gcd(x*y)*lcm(x*y)" }}{PARA 0 "" 0 "" 
{TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }{TEXT 287 3 "kp " }
{TEXT -1 6 "right!" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" 
{TEXT -1 147 "Use the Fundamental Theorem of Arithmetic to provide a w
ritten argument to verify the general formula that for any pair of pos
itive integers (m,n):" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 
"" {TEXT -1 34 "         mn = gcd(m,n) * lcm(m,n)." }}{PARA 0 "" 0 "" 
{TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT 274 125 "Argument:  All numbers \+
can be written as products of prime numbers.  The gcd and lcm are part
 of the prime number set for mn." }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}
{PARA 0 "" 0 "" {TEXT -1 0 "" }{TEXT 288 2 "kp" }{TEXT -1 77 "  aha!  \+
but why is gcd(m,n) * lcm(m,n) = mn and not just a part of it?   -1/2
" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 198 "8.  \+
 Numerical Approximations.  While Maple can perform exact arithmetic, \+
there are times when it is important or helpful to obtain a decimal ap
proximation for some exact answer.  For instance, the " }{TEXT 275 5 "
solve" }{TEXT -1 66 " command can be used to find the \"exact\" roots \+
of the polynomial  " }{XPPEDIT 18 0 "p := x^3-11*x^2-70*x+600;" "6#>%
\"pG,**$%\"xG\"\"$\"\"\"*&\"#6F)*$F'\"\"#F)!\"\"*&\"#qF)F'F)F.\"$+'F)
" }{TEXT -1 34 " .  Execute the following command:" }}{PARA 0 "" 0 "" 
{TEXT -1 0 "" }}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 7 "x:='x':" }}}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 45 "roots_of_p := solve(x^3-11*x
^2-70*x+600=0,x);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%+roots_of_pG6%
\"\"',&#\"\"&\"\"#\"\"\"*(F)F+F*!\"\"\"#<#F+F*F+,&F(F+*(F)F+F*F-F.F/F-
" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 0 "" }}}{PARA 0 "" 0 "" 
{TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 289 "That isn't very illumina
ting.  It maybe hard to tell, but there are three roots.  If you chang
e the problem slightly, it may be even harder.  (For example, change t
he number 70 in the above problem to 80 and then do the calculation!) \+
 To display each root separately, execute the commands:" }}{PARA 0 "" 
0 "" {TEXT -1 0 "" }}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 24 "r1 := R
e(roots_of_p[1]);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#r1G\"\"'" }}}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 24 "r2 := Re(roots_of_p[2]);" }}
{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#r2G,&#\"\"&\"\"#\"\"\"*(F'F)F(!\"\"
\"#<#F)F(F)" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 24 "r3 := Re(roo
