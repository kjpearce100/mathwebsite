&\"\"&!\"\"F&" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 19 "factor(h, \+
complex);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#*(,&%\"xG\"\"\"$\"+xz1OA!
\"*F&F&,&F%F&$F&\"\"!F&F&,&F%F&$\"+xz1OAF)!\"\"F&" }}}{EXCHG {PARA 0 "
" 0 "" {TEXT -1 104 "The factor, complex function allowed maple to fin
d three linear factors for this third degree polynomial" }}}{EXCHG 
