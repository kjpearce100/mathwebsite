)%\"xG\"\"$F(F(*&\"#6F()F*\"\"#F(F(*&F'F(F*F(F(F(F(" }}}{EXCHG {PARA 
0 "> " 0 "" {MPLTEXT 1 0 10 "factor(g);" }}{PARA 11 "" 1 "" {XPPMATH 
20 "6#*(,&*&\"\"#\"\"\"%\"xGF'F'F'F'F',&*&\"\"$F'F(F'F'F'F'F',&F(F'F'F
'F'" }}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 70 "Maple aslo found three lin
ear factors for this third degree polynomial" }}}{EXCHG {PARA 0 "> " 
