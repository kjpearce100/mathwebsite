{SECT 0 {PARA 256 "" 0 "" {TEXT 263 23 "Algebraic Manipulations" }}
{PARA 0 "" 0 "" {TEXT -1 15 "work02-babb.mws" }}{PARA 0 "" 0 "" {TEXT 
-1 179 "Save your current worksheet as work02-yourlastname.mws.  Remem
ber to save frequently to avoid losing data in case that the system wo
uld shut down in the middle of a work session! " }}{PARA 0 "" 0 "" 
{TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 104 "In the text mode (click \+
on the cap T button) place your name(s) and date at the top of your wo
rksheet.  " }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT 
-1 531 "1.  Basic Manipulations.  We can use Maple to manipulate algeb
raic expression as well as to perform arithmetic calculations.  The in
tent is to learn some basic Maple syntax, while observing some of the \+
neat features of a Computer Algebra System (CAS).  We will also review
 some basic concepts from arithmetic.   Perform the following calculat
ions with Maple.  As you do these exercises enter notes and comments o
nto your worksheet in text mode.  Note the usage of operators +,-,*,/,
^,!  and the usage or non-usage of parentheses.  " }}{PARA 0 "" 0 "" 
{TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 60 "Let the following variabl
es represent algebraic expressions:" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }
}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 21 "    f := x^3-x^2-2*x;" }}
{PARA 11 "" 1 "" {XPPMATH 20 "6#>%\"fG,(*$)%\"xG\"\"$\"\"\"F**$)F(\"\"
#F*!\"\"*&F-F*F(F*F." }}}{EXCHG {PARA 11 "" 1 "" {TEXT -1 0 "" }}}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 25 " g := 6*x^3+11*x^2+6*x+1;" }
}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%\"gG,**&\"\"'\"\"\")%\"xG\"\"$F(F(*
&\"#6F()F*\"\"#F(F(*&F'F(F*F(F(F(F(" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 22 "   h := x^3-5*x+x^2-5;" }}{PARA 11 "" 1 "" {XPPMATH 
20 "6#>%\"hG,**$)%\"xG\"\"$\"\"\"F**&\"\"&F*F(F*!\"\"*$)F(\"\"#F*F*F,F
-" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 14 "F := x^4-1;   " }}
{PARA 11 "" 1 "" {XPPMATH 20 "6#>%\"FG,&*$)%\"xG\"\"%\"\"\"F*F*!\"\"" 
}}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 29 "  G := 3*x^4+4*x^3-2*x^2+
x-6;" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%\"GG,,*&\"\"$\"\"\")%\"xG\"
\"%F(F(*&F+F()F*F'F(F(*&\"\"#F()F*F/F(!\"\"F*F(\"\"'F1" }}}{PARA 0 "" 
0 "" {TEXT -1 7 "\n1.    " }{XPPEDIT 19 1 "f := x^3-x^2-2*x" "6#>%\"fG
,(*$%\"xG\"\"$\"\"\"*$F'\"\"#!\"\"*&F+F)F'F)F," }}{EXCHG {PARA 0 "> " 
0 "" {MPLTEXT 1 0 17 "H := 2*x^2+3*x-2;" }}{PARA 11 "" 1 "" {XPPMATH 
20 "6#>%\"HG,(*&\"\"#\"\"\")%\"xGF'F(F(*&\"\"$F(F*F(F(F'!\"\"" }}}
