{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 4 "p1;\n" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#,&*$)%\"xG\"\"#\"\"\"F(F(!\"\"" }}}{EXCHG {PARA 0 "> " 
0 "" {MPLTEXT 1 0 3 "p2;" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#%#p2G" }}}
{PARA 0 "" 0 "" {TEXT -1 0 "" }}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 
6 "p2(x);" }}{PARA 0 "" 0 "" {TEXT -1 81 "Since the x is in the parent
hesis Maple knows to plug it into the equation of p1." }{TEXT 301 0 "
" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#,&*$)%\"xG\"\"#\"\"\"F(F(!\"\"" }}
}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 9 "p2(t-3);\n" }{TEXT 300 41 "M
