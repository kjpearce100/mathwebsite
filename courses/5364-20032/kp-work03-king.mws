F&F%F$" }}}{PARA 0 "" 0 "" {TEXT -1 4 "The " }{TEXT 259 16 "Binomial T
heorem" }{TEXT -1 66 " gives a formula for finding the coefficients of
 the expansion of " }{XPPEDIT 18 0 "(a+b)^n;" "6#),&%\"aG\"\"\"%\"bGF&
%\"nG" }{TEXT -1 10 "  for any " }{TEXT 266 1 "n" }{TEXT -1 53 ".  It \+
is relatively obvious that the coefficient of  " }{XPPEDIT 18 0 "a^(n-
k)*b^k;" "6#*&)%\"aG,&%\"nG\"\"\"%\"kG!\"\"F()%\"bGF)F(" }{TEXT -1 19 
"  for any value of " }{TEXT 267 1 "k" }{TEXT -1 11 " from 0 to " }
{TEXT 268 1 "n" }{TEXT -1 46 " is given by the number of ways we can c
hoose " }{TEXT 269 1 "k" }{TEXT -1 8 " of the " }{TEXT 293 1 "b" }
{TEXT -1 12 "'s from the " }{TEXT 270 1 "n" }{TEXT -1 1 " " }{TEXT 
294 1 "b" }{TEXT -1 20 "'s in the expansion " }{XPPEDIT 18 0 "(a+b)*(a
+b)" "6#*&,&%\"aG\"\"\"%\"bGF&F&,&F%F&F'F&F&" }{TEXT -1 7 " ....( " }
{XPPEDIT 18 0 "(a+b)" "6#,&%\"aG\"\"\"%\"bGF%" }{TEXT -1 5 " ),  " }
{TEXT 271 1 "n" }{TEXT -1 41 " times .   The number of combinations of
 " }{TEXT 272 1 "n" }{TEXT -1 18 " objects choosing " }{TEXT 273 1 "k
" }{TEXT -1 12 " at a time, " }{XPPEDIT 18 0 "C(n,k);" "6#-%\"CG6$%\"n
G%\"kG" }{TEXT -1 27 ", is given by the formula  " }{XPPEDIT 18 0 "C(n
,k) = n!/(k!*(n-k)!);" "6#/-%\"CG6$%\"nG%\"kG*&-%*factorialG6#F'\"\"\"
*&-F+6#F(F--F+6#,&F'F-F(!\"\"F-F4" }{TEXT -1 2 " ." }}{PARA 0 "" 0 "" 
{TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT 261 10 "State the " }{TEXT 260 
16 "Binomial Theorem" }{TEXT -1 1 " " }{TEXT 274 31 "and use Maple to \+
demonstrate it" }{TEXT -1 1 "." }}{PARA 0 "" 0 "" {TEXT -1 0 "" }
{TEXT 297 246 "* The  number of combinations of the coefficeints of an
 expansion for the value of k can be found by taking the factorial of \+
the coefficent divided by the factorial of k times the factorial of th
e resultant of the coeffiecent minus k.\nFor example" }}{EXCHG {PARA 
0 "> " 0 "" {MPLTEXT 1 0 52 "(a+b)^3;\nexpand ((a+b)^3);\ncoeffs(%);\n
3!/3!*(3-3)!;\n" }{TEXT -1 0 "" }{MPLTEXT 1 0 13 "3!/2!*(3-2)!;" }
{TEXT -1 89 " This formula figured the number of combinations for b to
 the power of  3 and power of 2." }}{PARA 11 "" 1 "" {XPPMATH 20 "6#*$
),&%\"aG\"\"\"%\"bGF'\"\"$F'" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#,**$)%
\"aG\"\"$\"\"\"F(*(F'F()F&\"\"#F(%\"bGF(F(*(F'F(F&F()F,F+F(F(*$)F,F'F(
F(" }}{PARA 11 "" 1 "" {XPPMATH 20 "6&\"\"\"\"\"$F$F#" }}{PARA 11 "" 
1 "" {XPPMATH 20 "6#\"\"\"" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#\"\"$" }
}}{PARA 0 "" 0 "" {TEXT -1 8 "Compute " }{XPPEDIT 18 0 "sum(binomial(n
,k),k=0..n)" "6#-%$sumG6$-%)binomialG6$%\"nG%\"kG/F*;\"\"!F)" }{TEXT 
-1 34 "  for n=1 to 10.  Here the symbol " }{XPPEDIT 18 0 "Sigma;" "6#
%&SigmaG" }{TEXT -1 70 " (Greek letter Sigma) stands for sum.   (See t
he worksheet SumSeq.mws)" }}{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 35 "Sum(k^1,k=0..10);\nsum(k^1,k
=0..10);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#-%$SumG6$%\"kG/F&;\"\"!\"#
5" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#\"#b" }}}{PARA 0 "" 0 "" {TEXT 
298 59 "What general formula do the above calculations in  suggest?" }
{TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT 310 74 "It represents sum of ari
thmeric series, this formula Sn=n/2*[2*a+(n-1)*d]." }}{PARA 0 "" 0 "" 
{TEXT -1 0 "" }}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 21 "Sn=n/2*[2*a+
(n-1)*d];" }}{PARA 0 "> " 0 "" {MPLTEXT 1 0 23 "Sn=11/2*[2*0+(11-1)*1]
;" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#/%#SnG,$*&#\"\"\"\"\"#F(*&%\"nGF(
7#,&*&F)F(%\"aGF(F(*&,&F+F(F(!\"\"F(%\"dGF(F(F(F(F(" }}{PARA 11 "" 1 "
" {XPPMATH 20 "6#/%#SnG7#\"#b" }}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 49 "
Add each of these numbers together from 0 to 10. " }{MPLTEXT 1 0 23 "1
