45.000000 0 0 "Curve 1" }}}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 0 "
" }}}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 4 "5.  \+
" }{TEXT 309 24 "Three-dimensional plots." }{TEXT -1 45 "  Maple can a
lso provide representations for " }{TEXT 310 37 "graphs of functions o
f two variables." }{TEXT -1 94 "  The graphs of such functions are sur
faces in three-dimensional space.  The Maple command is:" }}{PARA 0 "
" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 5 "     " }{TEXT 270 
0 "" }{TEXT 271 4 "plot" }{TEXT 272 2 "3d" }{TEXT -1 2 "( " }{TEXT 
273 4 "expr" }{TEXT -1 2 ", " }{TEXT 274 1 "x" }{TEXT -1 8 "=range, " 
}{TEXT 275 0 "" }{TEXT 276 2 "y=" }{TEXT -1 19 "range [, options]);" }
}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 6 "where " }
{TEXT 277 4 "expr" }{TEXT 281 1 " " }{TEXT -1 24 "is a symbolic expres
sion" }{TEXT 279 1 " " }{TEXT -1 48 "which represents the function to \+
be plotted and " }{TEXT 278 1 "x" }{TEXT -1 5 " and " }{TEXT 282 0 "" 
}{TEXT 283 1 "y" }{TEXT 284 0 "" }{TEXT -1 44 " are the two independen
t variables used in  " }{TEXT 280 4 "expr" }{TEXT -1 25 "  to define t
he function." }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT 
-1 4 "The " }{TEXT 285 0 "" }{TEXT 286 6 "plot3d" }{TEXT 287 0 "" }
{TEXT -1 238 " command will generate a surface plot for the function o
ver the rectangular range specfied in the command statement.  The surf
ace plot can be rotated, tipped over and turned around to see the surf
ace plot from all side and all viewpoints." }}{PARA 0 "" 0 "" {TEXT 
-1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 36 "For each of the following funct
ions " }{TEXT 311 37 "provide a plot which shows the graph." }{TEXT 
-1 8 "  Choose" }{TEXT 312 46 " reasonable values for the ranges of x \+
and y. " }{TEXT -1 1 " " }{TEXT 313 6 "Rotate" }{TEXT -1 21 ", where a
ppropriate, " }{TEXT 314 2 "to" }{TEXT -1 1 " " }{TEXT 315 32 "present
 a good view of the graph" }{TEXT -1 88 ".  The last two graphs are im
plicitly defined functions which require the Maple command " }{TEXT 
297 0 "" }{TEXT 298 15 "implicitplot3d " }{TEXT 299 0 "" }{TEXT -1 29 
"which is part of the package " }{TEXT 300 0 "" }{TEXT 301 5 "plots" }
{TEXT 302 0 "" }{TEXT -1 1 "." }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}
{PARA 0 "" 0 "" {TEXT -1 5 "a.   " }{XPPEDIT 18 0 "z" "6#%\"zG" }
{TEXT -1 5 " =   " }{XPPEDIT 18 0 "cos(2*x-y^2)" "6#-%$cosG6#,&*&\"\"#
\"\"\"%\"xGF)F)*$%\"yGF(!\"\"" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 17 "a5:=cos(2*x-y^2);" }}{PARA 
0 "> " 0 "" {MPLTEXT 1 0 27 "plot3d(a5,x=-2..2,y=-2..2);" }}{PARA 11 "
