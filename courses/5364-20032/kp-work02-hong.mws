{MPLTEXT 1 0 17 "H := 2*x^2+3*x-2:" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 0 "" }}}{PARA 0 "" 0 "" {TEXT -1 49 "Calcuate the followi
ng (each on a separate line):" }}{PARA 0 "" 0 "" {TEXT -1 123 "a.   f*
g                       b.   g*(h-f)                  c.   f^3        \+
         d.  (f + g)*(f - h) + (f - g)*(f + h)" }}{PARA 0 "" 0 "" 
{TEXT -1 141 "e.  F*H/G                  f.   (F/H)/G                 \+
g.  F/(H/G)           h.    F/H*G                                     \+
   i.   F/(H*G)" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{EXCHG {PARA 0 "> \+
" 0 "" {MPLTEXT 1 0 13 "factor(f*g );" }}{PARA 11 "" 1 "" {XPPMATH 20 
