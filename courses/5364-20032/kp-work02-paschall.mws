\"F-F(F(,&F*F(^$F0$!+['o&*\\\"F-F(F(F*F(,&F*F($\"+\"32Ig\"F-!\"\"F(F(
" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 39 "G1:=7*x^6-4*x^4+2;\n\nf
actor(G1,complex);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#G1G,(*&\"\"(
\"\"\")%\"xG\"\"'F(F(*&\"\"%F()F*F-F(!\"\"\"\"#F(" }}{PARA 12 "" 1 "" 
