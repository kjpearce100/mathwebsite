}}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#f1G,&*&\"\"$\"\"\"%\"xGF(F(F(!\"
\"" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 17 "f2:=6*x^2+24*x-8;" }}
{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#f2G,(*&\"\"'\"\"\")%\"xG\"\"#F(F(*&
