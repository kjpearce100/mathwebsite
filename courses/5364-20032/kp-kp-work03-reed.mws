31 "Note:  it is possible to use a " }{TEXT 283 9 "for loop " }{TEXT 
-1 69 " to simplify this task since we are doing a repetitive calculat
ion.  " }}{PARA 0 "" 0 "" {TEXT -1 29 "Note:  Also, the the command " 
}{TEXT 284 6 "coeffs" }{TEXT -1 15 " unfortunately " }{TEXT 285 8 "doe
s not" }{TEXT -1 36 " pick off the coefficients in order." }}{PARA 0 "
" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 4 "The " }{TEXT 280 
16 "Binomial Theorem" }{TEXT -1 66 " gives a formula for finding the c
oefficients of the expansion of " }{XPPEDIT 18 0 "(a+b)^n;" "6#),&%\"a
G\"\"\"%\"bGF&%\"nG" }{TEXT -1 10 "  for any " }{TEXT 286 1 "n" }
{TEXT -1 53 ".  It is relatively obvious that the coefficient of  " }
{XPPEDIT 18 0 "a^(n-k)*b^k;" "6#*&)%\"aG,&%\"nG\"\"\"%\"kG!\"\"F()%\"b
GF)F(" }{TEXT -1 19 "  for any value of " }{TEXT 287 1 "k" }{TEXT -1 
11 " from 0 to " }{TEXT 288 1 "n" }{TEXT -1 46 " is given by the numbe
r of ways we can choose " }{TEXT 289 1 "k" }{TEXT -1 8 " of the " }
{TEXT 295 1 "b" }{TEXT -1 12 "'s from the " }{TEXT 290 1 "n" }{TEXT 
-1 1 " " }{TEXT 296 1 "b" }{TEXT -1 20 "'s in the expansion " }
{XPPEDIT 18 0 "(a+b)*(a+b)" "6#*&,&%\"aG\"\"\"%\"bGF&F&,&F%F&F'F&F&" }
{TEXT -1 7 " ....( " }{XPPEDIT 18 0 "(a+b)" "6#,&%\"aG\"\"\"%\"bGF%" }
{TEXT -1 5 " ),  " }{TEXT 291 1 "n" }{TEXT -1 41 " times .   The numbe
r of combinations of " }{TEXT 292 1 "n" }{TEXT -1 18 " objects choosin
g " }{TEXT 293 1 "k" }{TEXT -1 12 " at a time, " }{XPPEDIT 18 0 "nCk" 
"6#%$nCkG" }{TEXT -1 27 ", is given by the formula  " }{XPPEDIT 18 0 "
nCk=n!/(k!*(n-k)!)" "6#/%$nCkG*&-%*factorialG6#%\"nG\"\"\"*&-F'6#%\"kG
F*-F'6#,&F)F*F.!\"\"F*F2" }{TEXT -1 2 " ." }}{PARA 0 "" 0 "" {TEXT -1 
8 "Compute " }{XPPEDIT 18 0 "sum(binomial(n,k),k=0..n)" "6#-%$sumG6$-%
)binomialG6$%\"nG%\"kG/F*;\"\"!F)" }{TEXT -1 34 "  for n=1 to 10.  Her
e the symbol " }{XPPEDIT 18 0 "Sigma;" "6#%&SigmaG" }{TEXT -1 70 " (Gr
eek letter Sigma) stands for sum.   (See the worksheet SumSeq.mws)" }}
{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT 282 10 "State th
e " }{TEXT 281 16 "Binomial Theorem" }{TEXT -1 1 " " }{TEXT 294 31 "an
d use Maple to demonstrate it" }{TEXT -1 1 "." }}{EXCHG {PARA 0 "" 0 "
" {TEXT -1 23 "The coefficient of the " }{TEXT 299 1 "k" }{TEXT -1 28 
"th term of the expansion of " }{TEXT 298 0 "" }{XPPEDIT 18 0 "(a+b)^n
;" "6#),&%\"aG\"\"\"%\"bGF&%\"nG" }}{PARA 0 "" 0 "" {TEXT -1 25 " is g
iven by the formula " }{XPPEDIT 18 0 "nCk=n!/(k!*(n-k)!)" "6#/%$nCkG*&
-%*factorialG6#%\"nG\"\"\"*&-F'6#%\"kGF*-F'6#,&F)F*F.!\"\"F*F2" }}}
{PARA 258 "" 0 "" {TEXT -1 1 " " }}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 
1 0 50 "for n from 1 to 10\ndo\n  seq(n!/(k!*(n-k)!),k=0..n)" }}{PARA 
0 "> " 0 "" {MPLTEXT 1 0 3 "od;" }}{PARA 0 "> " 0 "" {MPLTEXT 1 0 0 "
" }}{PARA 11 "" 1 "" {XPPMATH 20 "6$\"\"\"F#" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6%\"\"\"\"\"#F#" }}{PARA 11 "" 1 "" {XPPMATH 20 "6&\"\"\"
\"\"$F$F#" }}{PARA 11 "" 1 "" {XPPMATH 20 "6'\"\"\"\"\"%\"\"'F$F#" }}
{PARA 11 "" 1 "" {XPPMATH 20 "6(\"\"\"\"\"&\"#5F%F$F#" }}{PARA 11 "" 
1 "" {XPPMATH 20 "6)\"\"\"\"\"'\"#:\"#?F%F$F#" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6*\"\"\"\"\"(\"#@\"#NF&F%F$F#" }}{PARA 11 "" 1 "" 
