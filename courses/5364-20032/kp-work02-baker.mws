{SECT 0 {PARA 256 "" 0 "" {TEXT 263 23 "Algebraic Manipulations" }}
{PARA 0 "" 0 "" {TEXT -1 18 "John Baker 3/31/03" }}{PARA 0 "" 0 "" 
{TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 179 "Save your current worksh
eet as work02-yourlastname.mws.  Remember to save frequently to avoid \+
losing data in case that the system would shut down in the middle of a
 work session! " }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" 
{TEXT -1 104 "In the text mode (click on the cap T button) place your \+
name(s) and date at the top of your worksheet.  " }}{PARA 0 "" 0 "" 
{TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 531 "1.  Basic Manipulations.
  We can use Maple to manipulate algebraic expression as well as to pe
rform arithmetic calculations.  The intent is to learn some basic Mapl
e syntax, while observing some of the neat features of a Computer Alge
bra System (CAS).  We will also review some basic concepts from arithm
etic.   Perform the following calculations with Maple.  As you do thes
e exercises enter notes and comments onto your worksheet in text mode.
  Note the usage of operators +,-,*,/,^,!  and the usage or non-usage \+
of parentheses.  " }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" 
{TEXT -1 60 "Let the following variables represent algebraic expressio
ns:" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 7 "1. \+
    " }{XPPEDIT 19 1 "f := x^3-x^2-2*x" "6#>%\"fG,(*$%\"xG\"\"$\"\"\"*
$F'\"\"#!\"\"*&F+F)F'F)F," }{TEXT -1 10 "     2.   " }{XPPEDIT 19 1 "g
 := 6*x^3+11*x^2+6*x+1" "6#>%\"gG,**&\"\"'\"\"\"*$%\"xG\"\"$F(F(*&\"#6
F(*$F*\"\"#F(F(*&F'F(F*F(F(F(F(" }{TEXT -1 22 "                 3.   \+
" }{XPPEDIT 19 1 "h := x^3-5*x+x^2-5;" "6#>%\"hG,**$%\"xG\"\"$\"\"\"*&
\"\"&F)F'F)!\"\"*$F'\"\"#F)F+F," }{TEXT -1 19 "                   " }}
{PARA 0 "" 0 "" {TEXT -1 6 "4.    " }{XPPEDIT 19 1 "F := x^4-1" "6#>%
\"FG,&*$%\"xG\"\"%\"\"\"F)!\"\"" }{TEXT -1 22 "                5.    \+
" }{XPPEDIT 19 1 "G := 3*x^4+4*x^3-2*x^2+x-6;" "6#>%\"GG,,*&\"\"$\"\"
\"*$%\"xG\"\"%F(F(*&F+F(*$F*F'F(F(*&\"\"#F(*$F*F/F(!\"\"F*F(\"\"'F1" }
{TEXT -1 14 "         6.   " }{XPPEDIT 19 1 "H := 2*x^2+3*x-2" "6#>%\"
HG,(*&\"\"#\"\"\"*$%\"xGF'F(F(*&\"\"$F(F*F(F(F'!\"\"" }{TEXT -1 24 "  \+
                      " }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 
0 "" {TEXT -1 49 "Calcuate the following (each on a separate line):" }
}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 123 "a.   f*
g                       b.   g*(h-f)                  c.   f^3        \+
         d.  (f + g)*(f - h) + (f - g)*(f + h)" }}{PARA 0 "" 0 "" 
{TEXT -1 141 "e.  F*H/G                  f.   (F/H)/G                 \+
g.  F/(H/G)           h.    F/H*G                                     \+
   i.   F/(H*G)" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{EXCHG {PARA 0 "> \+
" 0 "" {MPLTEXT 1 0 15 "f:=x^3-x^2-2*x;" }}{PARA 11 "" 1 "" {XPPMATH 
20 "6#>%\"fG,(*$)%\"xG\"\"$\"\"\"F**$)F(\"\"#F*!\"\"*&F-F*F(F*F." }}}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 22 "g:=6*x^3+11*x^2+6*x+1;" }}
{PARA 11 "" 1 "" {XPPMATH 20 "6#>%\"gG,**&\"\"'\"\"\")%\"xG\"\"$F(F(*&
\"#6F()F*\"\"#F(F(*&F'F(F*F(F(F(F(" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 17 "h:=x^3-5*x+x^2-5;" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#
>%\"hG,**$)%\"xG\"\"$\"\"\"F**&\"\"&F*F(F*!\"\"*$)F(\"\"#F*F*F,F-" }}}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 9 "F:=x^4-1;" }}{PARA 11 "" 1 "
" {XPPMATH 20 "6#>%\"FG,&*$)%\"xG\"\"%\"\"\"F*F*!\"\"" }}}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 25 "G:=3*x^4+4*x^3-2*x^2+x-6;" }}{PARA 
11 "" 1 "" {XPPMATH 20 "6#>%\"GG,,*&\"\"$\"\"\")%\"xG\"\"%F(F(*&F+F()F
*F'F(F(*&\"\"#F()F*F/F(!\"\"F*F(\"\"'F1" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 15 "H:=2*x^2+3*x-2;" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%
\"HG,(*&\"\"#\"\"\")%\"xGF'F(F(*&\"\"$F(F*F(F(F'!\"\"" }}}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 5 ":f*g;" }}{PARA 11 "" 1 "" {XPPMATH 
20 "6#*&,(*$)%\"xG\"\"$\"\"\"F)*$)F'\"\"#F)!\"\"*&F,F)F'F)F-F),**&\"\"
'F)F&F)F)*&\"#6F)F+F)F)*&F1F)F'F)F)F)F)F)" }}}{EXCHG {PARA 0 "> " 0 "
" {MPLTEXT 1 0 9 ":g*(h-f);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#*&,**&
\"\"'\"\"\")%\"xG\"\"$F'F'*&\"#6F')F)\"\"#F'F'*&F&F'F)F'F'F'F'F',(*&F*
F'F)F'!\"\"*&F.F'F-F'F'\"\"&F2F'" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 5 ":f^3;" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#*$),(*$)%\"xG
\"\"$\"\"\"F**$)F(\"\"#F*!\"\"*&F-F*F(F*F.F)F*" }}}{EXCHG {PARA 0 "> \+
" 0 "" {MPLTEXT 1 0 36 " :(f + g)*(f - h) + (f - g)*(f + h);" }}{PARA 
11 "" 1 "" {XPPMATH 20 "6#,&*&,**&\"\"(\"\"\")%\"xG\"\"$F(F(*&\"#5F()F
*\"\"#F(F(*&\"\"%F(F*F(F(F(F(F(,(*&F/F(F.F(!\"\"*&F+F(F*F(F(\"\"&F(F(F
(*&,**&F6F(F)F(F4*&\"#7F(F.F(F4*&\"\")F(F*F(F4F(F4F(,(*&F/F(F)F(F(*&F'
F(F*F(F4F6F4F(F(" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 7 ":F*H/G;
" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#*(,&*$)%\"xG\"\"%\"\"\"F)F)!\"\"F)
,(*&\"\"#F))F'F-F)F)*&\"\"$F)F'F)F)F-F*F),,*&F0F)F&F)F)*&F(F))F'F0F)F)
*&F-F)F.F)F*F'F)\"\"'F*F*" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 
12 " :(F/H)/G;  " }}{PARA 11 "" 1 "" {XPPMATH 20 "6#*(,&*$)%\"xG\"\"%
\"\"\"F)F)!\"\"F),(*&\"\"#F))F'F-F)F)*&\"\"$F)F'F)F)F-F*F*,,*&F0F)F&F)
F)*&F(F))F'F0F)F)*&F-F)F.F)F*F'F)\"\"'F*F*" }}}{EXCHG {PARA 0 "> " 0 "
" {MPLTEXT 1 0 9 ":F/(H/G);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#*(,&*$)
%\"xG\"\"%\"\"\"F)F)!\"\"F),(*&\"\"#F))F'F-F)F)*&\"\"$F)F'F)F)F-F*F*,,
*&F0F)F&F)F)*&F(F))F'F0F)F)*&F-F)F.F)F*F'F)\"\"'F*F)" }}}{EXCHG {PARA 
0 "> " 0 "" {MPLTEXT 1 0 8 ":F/H*G; " }}{PARA 11 "" 1 "" {XPPMATH 20 "
6#*(,&*$)%\"xG\"\"%\"\"\"F)F)!\"\"F),(*&\"\"#F))F'F-F)F)*&\"\"$F)F'F)F
)F-F*F*,,*&F0F)F&F)F)*&F(F))F'F0F)F)*&F-F)F.F)F*F'F)\"\"'F*F)" }}}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 10 " :F/(H*G);" }}{PARA 11 "" 1 
"" {XPPMATH 20 "6#*(,&*$)%\"xG\"\"%\"\"\"F)F)!\"\"F),(*&\"\"#F))F'F-F)
F)*&\"\"$F)F'F)F)F-F*F*,,*&F0F)F&F)F)*&F(F))F'F0F)F)*&F-F)F.F)F*F'F)\"
\"'F*F*" }}}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 
162 "As you may have noted the addition/subtraction operatios where ca
rried out while the multiplication/division operations were just indic
ated.  The Maple commands  " }{TEXT 264 6 "expand" }{TEXT -1 6 " and  \+
" }{TEXT 265 8 "simplify" }{TEXT -1 298 "  can be used to rearrange an
d manipulate algebraic sums and products of polynomial expressions.  G
o back to each of your calculations of a., b., c. and d. and add to ea
ch line a command to expand the calculation and a command to simplify \+
the caclulation.  E.g.,  the line for a. would change from:" }}{PARA 
0 "" 0 "" {TEXT -1 1 " " }}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 4 "f*
g;" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#*&,(*$)%\"xG\"\"$\"\"\"F)*$)F'\"
\"#F)!\"\"*&F,F)F'F)F-F),**&\"\"'F)F&F)F)*&\"#6F)F+F)F)*&F1F)F'F)F)F)F
)F)" }}}{PARA 0 "" 0 "" {TEXT -1 3 "to " }}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 32 "f*g; expand(f*g); simplify(f*g);" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#*&,(*$)%\"xG\"\"$\"\"\"F)*$)F'\"\"#F)!\"\"*&F,F)F'F)F-F
),**&\"\"'F)F&F)F)*&\"#6F)F+F)F)*&F1F)F'F)F)F)F)F)" }}{PARA 11 "" 1 "
" {XPPMATH 20 "6#,.*&\"\"'\"\"\")%\"xGF%F&F&*&\"\"&F&)F(F*F&F&*&\"#<F&
)F(\"\"%F&!\"\"*&\"#FF&)F(\"\"$F&F0*&\"#8F&)F(\"\"#F&F0*&F8F&F(F&F0" }
}{PARA 11 "" 1 "" {XPPMATH 20 "6#*(%\"xG\"\"\",(*$)F$\"\"#F%F%F$!\"\"F
)F*F%,**&\"\"'F%)F$\"\"$F%F%*&\"#6F%F(F%F%*&F-F%F$F%F%F%F%F%" }}}
{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 17 "Note the \+
effect  " }{TEXT 268 6 "expand" }{TEXT -1 5 " and " }{TEXT 269 8 "simp
lify" }{TEXT -1 42 "  have on the way the calculation appears." }}
{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 19 "The Maple
 commands " }{TEXT 266 16 "expand, simplify" }{TEXT -1 5 " and " }
{TEXT 267 6 "normal" }{TEXT -1 483 " can be use to rearrange, manipula
te and simplify (cancel common factors) algebraic sums, products and q
uotients of rational expressions.   When a rational expression is norm
alized, any common factors are cancelled.  Go back to each of your cal
culations of e., f., g., h. and i. and add to each line a command to e
xpand the calculation, to normalize the calculation, to simplify the c
alculation and both expand and normalize the calculation.  E.g., the l
ine for e. would change from:" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 6 "F*H/G;" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#*(,&*$)%\"xG\"\"%\"\"\"F)F)!\"\"F),(*&\"\"#F))F'F-F)F)*
&\"\"$F)F'F)F)F-F*F),,*&F0F)F&F)F)*&F(F))F'F0F)F)*&F-F)F.F)F*F'F)\"\"'
F*F*" }}}{PARA 0 "" 0 "" {TEXT -1 2 "to" }}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 99 "F*H/G; expand(F*H/G); normal(F*H/G); simplify(F*H/G);
 expand(normal(F*H/G)); normal(expand(F*H/G));" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#*(,&*$)%\"xG\"\"%\"\"\"F)F)!\"\"F),(*&\"\"#F))F'F-F)F)*
&\"\"$F)F'F)F)F-F*F),,*&F0F)F&F)F)*&F(F))F'F0F)F)*&F-F)F.F)F*F'F)\"\"'
F*F*" }}{PARA 12 "" 1 "" {XPPMATH 20 "6#,.*(\"\"#\"\"\",,*&\"\"$F&)%\"
xG\"\"%F&F&*&F,F&)F+F)F&F&*&F%F&)F+F%F&!\"\"F+F&\"\"'F1F1F+F2F&*(F)F&F
'F1F+\"\"&F&*(F%F&F'F1F+F,F1*(F%F&F'F1F+F%F1*(F)F&F'F1F+F&F1*&F%F&F'F1
F&" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#*(,&*&\"\"#\"\"\"%\"xGF'F'F'!\"
\"F',**$)F(\"\"$F'F'*$)F(F&F'F'F(F'F'F'F',(*&F-F'F/F'F'F(F'F-F'F)" }}
{PARA 11 "" 1 "" {XPPMATH 20 "6#*(,&*&\"\"#\"\"\"%\"xGF'F'F'!\"\"F',**
$)F(\"\"$F'F'*$)F(F&F'F'F(F'F'F'F',(*&F-F'F/F'F'F(F'F-F'F)" }}{PARA 
11 "" 1 "" {XPPMATH 20 "6#,,*(\"\"#\"\"\",(*&\"\"$F&)%\"xGF%F&F&F+F&F)
F&!\"\"F+\"\"%F&*&F'F,F+F)F&*&F'F,F+F%F&*&F'F,F+F&F&*&F&F&F'F,F," }}
{PARA 11 "" 1 "" {XPPMATH 20 "6#*&,,*&\"\"#\"\"\")%\"xG\"\"%F'F'*$)F)
\"\"$F'F'*$)F)F&F'F'F)F'F'!\"\"F',(*&F-F'F/F'F'F)F'F-F'F0" }}}{PARA 0 
"" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 17 "Note the effect  \+
" }{TEXT 270 6 "expand" }{TEXT -1 2 ", " }{TEXT 272 6 "normal" }{TEXT 
-1 3 ",  " }{TEXT 271 8 "simplify" }{TEXT -1 10 " and both " }{TEXT 
273 6 "expand" }{TEXT -1 5 " and " }{TEXT 274 6 "normal" }{TEXT -1 42 
"  have on the way the calculation appears." }}{PARA 0 "" 0 "" {TEXT 
-1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 35 "2.  Factoring.  The Maple comma
nd  " }{TEXT 275 6 "factor" }{TEXT -1 299 " can be used to factor alge
braic polynomial expressions and rational expressions.  When rational \+
expressions are factors, any common factors are cancelled.  Factor eac
h of the polynomials f, g, h, F, G and H.  Also, factor the algebraic \+
and rational expressions a., b., c., d., e., f., g., h. and i." }}
{PARA 0 "" 0 "" {TEXT -1 0 "" }}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 
36 "factor:(f);\n(g);\n(h);\n(F);\n(G);\n(H);" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#,(*$)%\"xG\"\"$\"\"\"F(*$)F&\"\"#F(!\"\"*&F+F(F&F(F," }
}{PARA 11 "" 1 "" {XPPMATH 20 "6#,**&\"\"'\"\"\")%\"xG\"\"$F&F&*&\"#6F
&)F(\"\"#F&F&*&F%F&F(F&F&F&F&" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#,**$)
%\"xG\"\"$\"\"\"F(*&\"\"&F(F&F(!\"\"*$)F&\"\"#F(F(F*F+" }}{PARA 11 "" 
1 "" {XPPMATH 20 "6#,&*$)%\"xG\"\"%\"\"\"F(F(!\"\"" }}{PARA 11 "" 1 "
" {XPPMATH 20 "6#,,*&\"\"$\"\"\")%\"xG\"\"%F&F&*&F)F&)F(F%F&F&*&\"\"#F
&)F(F-F&!\"\"F(F&\"\"'F/" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#,(*&\"\"#
\"\"\")%\"xGF%F&F&*&\"\"$F&F(F&F&F%!\"\"" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 105 "factor:f*g;\ng*(h-f);\n\n f^3;\n(f + g)*(f - h) + (f
 - g)*(f + h);\nF*H/G;\n(F/H)/G;\nF/(H/G);\n F/H*G;\nF/(H*G); " }}
{PARA 0 "" 0 "" {TEXT -1 3 "   " }}{PARA 0 "> " 0 "" {MPLTEXT 1 0 0 "
" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#*&,(*$)%\"xG\"\"$\"\"\"F)*$)F'\"\"
#F)!\"\"*&F,F)F'F)F-F),**&\"\"'F)F&F)F)*&\"#6F)F+F)F)*&F1F)F'F)F)F)F)F
