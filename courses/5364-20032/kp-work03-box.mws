{PARA 0 "> " 0 "" {MPLTEXT 1 0 29 "eq5:=y = x-x^2;\neq6:=y = x-4;" }}
{PARA 11 "" 1 "" {XPPMATH 20 "6#>%$eq5G/%\"yG,&%\"xG\"\"\"*$)F(\"\"#F)
