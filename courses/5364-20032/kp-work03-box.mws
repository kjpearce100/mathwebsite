\"$F&F%F&F&F&F'F&,&*&\"\"#F&F%F&F&F&F&F&,&*$)F%F-F&F&F&F&F&" }}}{PARA 
0 "" 0 "" {TEXT -1 1 " " }}{PARA 0 "" 0 "" {TEXT -1 56 "5.  Solving Sy
stems of Equations in Several Variables.  " }}{PARA 0 "" 0 "" {TEXT 
-1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 49 "When we have an equation in two
 variables, e.g.  " }{XPPEDIT 19 1 "3*x -2*y = 5" "6#/,&*&\"\"$\"\"\"%
\"xGF'F'*&\"\"#F'%\"yGF'!\"\"\"\"&" }{TEXT -1 147 "  we often associat
e with it a graph, the set of points (x,y) in the two-dimensional plan
e which satisfy the equation.  For a linear equation like " }{XPPEDIT 
19 1 "3*x-2*y = 5" "6#/,&*&\"\"$\"\"\"%\"xGF'F'*&\"\"#F'%\"yGF'!\"\"\"
\"&" }{TEXT -1 89 " the graph is a straight line.  For more a complica
ted equation in two variables, e.g.,  " }{XPPEDIT 19 1 "2*x^3 -3*x + y
^2 = x*y" "6#/,(*&\"\"#\"\"\"*$%\"xG\"\"$F'F'*&F*F'F)F'!\"\"*$%\"yGF&F
'*&F)F'F.F'" }{TEXT -1 45 "  the graph becomes a more complicated curv
e." }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 282 "Wh
en we have two equations in two variables, we think of the solution se
t of this system of equations as being the set of points (x,y) which s
atisfy both equations simultaneously.  In terms of their graphs, the s
olution set is the set of points where the graphs intersect (cross).  \+
" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 622 "When
 we have two linear equations in two variables, since their graphs are
 straight lines, then two straight lines, if they cross, will cross in
 exactly one place.  Hence, the solution set of the system of equation
s will be exactly one point (x,y).  If we have two equations which are
 more complicated, then the number of intersection points (crossing po
ints) of their graphs can vary.  For example, if the graph of one equa
tion is a circle and the graph of the other equation is a straight lin
e, then, if their graphs cross, then number of solutions (intersection
 points) of the system of equations could be 1 or 2.  Etc." }}{PARA 0 
"" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 128 "We can instruct \+
Maple to find solutions of systems of equations using the solve or fso
lve commands.  The syntax for doing so is:" }}{PARA 0 "" 0 "" {TEXT 
-1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 30 "     solve( \{eq1,eq2\}, \{x,y
\});" }}{PARA 0 "" 0 "" {TEXT -1 1 " " }}{PARA 0 "" 0 "" {TEXT -1 85 "
where eq1 and eq2 are equations in the variables x and y.  This is ill
ustrated below." }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{EXCHG {PARA 0 "> \+
" 0 "" {MPLTEXT 1 0 42 "solve(\{ x + 2*y = 5, 2*x-3*y = -1\},\{x,y\});
" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#<$/%\"xG#\"#8\"\"(/%\"yG#\"#6F(" }
}}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 22 "We coul
d have defined " }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" 
{TEXT -1 0 "" }}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 40 "eq1 := x + 2
*y = 5;\neq2 := 2*x-3*y = -1;" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%$eq
1G/,&%\"xG\"\"\"*&\"\"#F(%\"yGF(F(\"\"&" }}{PARA 11 "" 1 "" {XPPMATH 
20 "6#>%$eq2G/,&*&\"\"#\"\"\"%\"xGF)F)*&\"\"$F)%\"yGF)!\"\"F." }}}
{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 26 "and then \+
given the command" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" 
{TEXT -1 0 "" }}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 25 "solve( \{eq1
,eq2\}, \{x,y\});" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#<$/%\"xG#\"#8\"\"
(/%\"yG#\"#6F(" }}}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" 
{TEXT -1 55 "and achieved the same result.  Remember the solution  (" 
}{XPPEDIT 19 1 "13/7" "6#*&\"#8\"\"\"\"\"(!\"\"" }{TEXT -1 2 ", " }
{XPPEDIT 19 1 "11/7" "6#*&\"#6\"\"\"\"\"(!\"\"" }{TEXT -1 127 ") repre
sents a point in the two-dimensional plane (why two-dimensional?) wher
e the graphs of the equations intersect (cross).  " }}{PARA 0 "" 0 "" 
{TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 63 "Find the solutions, if th
ey exist, for the following equations " }}{PARA 0 "" 0 "" {TEXT -1 0 "
" }}{PARA 0 "" 0 "" {TEXT -1 4 "a.  " }{XPPEDIT 19 1 "3*x - 2*y = 6" "
6#/,&*&\"\"$\"\"\"%\"xGF'F'*&\"\"#F'%\"yGF'!\"\"\"\"'" }{TEXT -1 3 ", \+
 " }{XPPEDIT 19 1 "4*x + y = -2" "6#/,&*&\"\"%\"\"\"%\"xGF'F'%\"yGF',$
\"\"#!\"\"" }}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 34 "eq1:=3*x-2*y =
 6;\neq2:=4*x+y = -2;" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%$eq1G/,&*&
\"\"$\"\"\"%\"xGF)F)*&\"\"#F)%\"yGF)!\"\"\"\"'" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#>%$eq2G/,&*&\"\"%\"\"\"%\"xGF)F)%\"yGF)!\"#" }}}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 25 "solve( \{eq1,eq2\}, \{x,y\});" }}
{PARA 11 "" 1 "" {XPPMATH 20 "6#<$/%\"yG#!#I\"#6/%\"xG#\"\"#F(" }}}
{PARA 0 "" 0 "" {TEXT -1 4 "b.  " }{XPPEDIT 19 1 "6*x -9*y = 12" "6#/,
&*&\"\"'\"\"\"%\"xGF'F'*&\"\"*F'%\"yGF'!\"\"\"#7" }{TEXT -1 3 ",  " }
{XPPEDIT 19 1 "3*y - 2*x = 3" "6#/,&*&\"\"$\"\"\"%\"yGF'F'*&\"\"#F'%\"
xGF'!\"\"F&" }}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 36 "eq3:=6*x-9*y \+
= 12;\neq4:=3*y-2*x = 3;" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%$eq3G/,&
*&\"\"'\"\"\"%\"xGF)F)*&\"\"*F)%\"yGF)!\"\"\"#7" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#>%$eq4G/,&*&\"\"$\"\"\"%\"yGF)F)*&\"\"#F)%\"xGF)!\"\"F(
" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 25 "solve( \{eq3,eq4\}, \{x
,y\});" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 41 "solve(\{6*x-9*y =
 12, 3*y-2*x = 3\},\{x,y\});" }{TEXT -1 36 "  I don't know why this wo
n't solve!" }}}{PARA 0 "" 0 "" {TEXT -1 4 "c.  " }{XPPEDIT 19 1 "y = x
 - x^2" "6#/%\"yG,&%\"xG\"\"\"*$F&\"\"#!\"\"" }{TEXT -1 3 ",  " }
