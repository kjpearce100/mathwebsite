\"%!\"\"" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 25 "solve( \{eq5,eq
6\}, \{x,y\});" }}{PARA 11 "" 1 "" {XPPMATH 20 "6$<$/%\"yG!\"#/%\"xG\"
\"#<$/F%!\"'/F(F&" }}}{PARA 0 "" 0 "" {TEXT -1 4 "d.  " }{XPPEDIT 19 
