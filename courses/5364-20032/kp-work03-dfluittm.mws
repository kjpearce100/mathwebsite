F&\"\"'F(F(*&\"#@F()F&\"\"&F(F(*&\"#NF()F&\"\"%F(F(*&F1F()F&\"\"$F(F(*
&F-F()F&\"\"#F(F(*&F'F(F&F(F(F(F(" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 19 "coeff((a+b)^7,a,4);" }}{PARA 11 "" 1 "" {XPPMATH 20 "
6#,$*&\"#N\"\"\")%\"bG\"\"$F&F&" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 
1 0 19 "coeff((a+1)^7,a,4);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#\"#N" }
}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 31 "seq(coeff((a+1)^5,a,n),n=0
..5);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6(\"\"\"\"\"&\"#5F%F$F#" }}}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 57 "for p from 0 to 10\ndo\nseq(
coeff((a+1)^p,a,n),n=0..p);\nod;" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#\"
\"\"" }}{PARA 11 "" 1 "" {XPPMATH 20 "6$\"\"\"F#" }}{PARA 11 "" 1 "" 
