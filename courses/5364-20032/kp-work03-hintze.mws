{MPLTEXT 1 0 14 "f1:=((a+1)^j);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#
f1G),&%\"aG\"\"\"F(F(%\"jG" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 
64 "for j from 1 to 10\ndo\nexpand(f1);\nseq(coeff(f1,a,i),i=0..j);\no
d;" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#,&%\"aG\"\"\"F%F%" }}{PARA 11 "
" 1 "" {XPPMATH 20 "6$\"\"\"F#" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#,(*$
