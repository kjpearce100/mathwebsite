{PARA 11 "" 1 "" {XPPMATH 20 "6#>%$eq3G/,&*&\"\"'\"\"\"%\"xGF)F)*&\"\"
*F)%\"yGF)!\"\"\"#7" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%$eq4G/,&*&\"
\"$\"\"\"%\"yGF)F)*&\"\"#F)%\"xGF)!\"\"F(" }}}{EXCHG {PARA 0 "> " 0 "
" {MPLTEXT 1 0 25 "solve( \{eq3,eq4\}, \{x,y\});" }}}{EXCHG {PARA 0 ">
