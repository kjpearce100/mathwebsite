" {TEXT -1 46 "1.  Binomial Theorem.  Use the Maple command  " }{TEXT 
262 6 "expand" }{TEXT 256 2 "  " }{TEXT -1 34 "to calculate the expans
ion of     " }{XPPEDIT 18 0 "(a+b)^n;" "6#),&%\"aG\"\"\"%\"bGF&%\"nG" 
}{TEXT -1 63 "    for values n=1..10 .  In each case use the Maple com
mand   " }{TEXT 257 7 "coeffs " }{TEXT 264 1 " " }{TEXT -1 84 "to pick
 off the coefficients.   For example,  if n=5 we would execute the fol
lowing:" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 27 "expand((a+b)^5);
\ncoeffs(%);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#,.*$)%\"aG\"\"&\"\"\"F
(*(F'F()F&\"\"%F(%\"bGF(F(*(\"#5F()F&\"\"$F()F,\"\"#F(F(*(F.F()F&F2F()
F,F0F(F(*(F'F(F&F()F,F+F(F(*$)F,F'F(F(" }}{PARA 11 "" 1 "" {XPPMATH 
20 "6(\"\"&F#\"#5F$\"\"\"F%" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 
19 "f:=expand((a+1)^5);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%\"fG,.*$)
%\"aG\"\"&\"\"\"F**&F)F*)F(\"\"%F*F**&\"#5F*)F(\"\"$F*F**&F/F*)F(\"\"#
F*F**&F)F*F(F*F*F*F*" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 25 "seq
(coeff(f,a,i),i=1..5);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6'\"\"&\"#5F$F
#\"\"\"" }}}{PARA 0 "" 0 "" {TEXT -1 28 "Do the rest from 1 to 10.   \+
" }}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 41 "for n from 1 to 10\ndo\n
expand((a+b)^n)\nod;" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#,&%\"aG\"\"\"%
\"bGF%" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#,(*$)%\"aG\"\"#\"\"\"F(*(F'F
