-F&6#\"\"&F(F*-F&6#\"$t\"F*" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 
15 "ifactor(10!)+1;" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#,&**)-%!G6#\"\"
#\"\")\"\"\")-F'6#\"\"$\"\"%F+)-F'6#\"\"&F)F+-F'6#\"\"(F+F+F+F+" }}}
