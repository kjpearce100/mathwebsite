F&6#\"\"&F*-F&6#\"#BF*-F&6#\"&*HjF*" }}}{PARA 0 "" 0 "" {TEXT -1 0 "" 
}}{PARA 0 "" 0 "" {TEXT -1 384 "7.  Greatest Common Divisors and Least
 Common Multiple (and the Fundamental Theorem of Arithmetic).  Maple c
an compute for a pair of integers (a,b) both the greatest common divis
or of  (a,b) and the least common multiple of (a,b) easily.  The comma
nds for doing so are gcd(a,b) and lcm(a,b), respectively.  For each of
 the following pairs (a,b) find both the gcd(a,b) and the lcm(a,b)" }}
{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 105 "a.  74,1
48           b.  201, 1001         c.  202, 1002     d.  2432902008176
640000,41758540970065920000" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 
0 "" 0 "" {TEXT -1 74 "For the pair of numbers 144 and 84 execute the \+
following command sequence:" }}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 
33 "144=ifactor(144);\n84=ifactor(84);" }}{PARA 11 "" 1 "" {XPPMATH 
20 "6#/\"$W\"*&)-%!G6#\"\"#\"\"%\"\"\")-F(6#\"\"$F*F," }}{PARA 11 "" 
1 "" {XPPMATH 20 "6#/\"#%)*()-%!G6#\"\"#F*\"\"\"-F(6#\"\"$F+-F(6#\"\"(
F+" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 23 "144*84=ifactor(144*84
);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#/\"&'47*()-%!G6#\"\"#\"\"'\"\"\"
)-F(6#\"\"$F0F,-F(6#\"\"(F," }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 
33 "gcd(144,84)=ifactor(gcd(144,84));" }}{PARA 11 "" 1 "" {XPPMATH 20 
"6#/\"#7*&)-%!G6#\"\"#F*\"\"\"-F(6#\"\"$F+" }}}{EXCHG {PARA 0 "> " 0 "
" {MPLTEXT 1 0 33 "lcm(144,84)=ifactor(lcm(144,84));" }}{PARA 11 "" 1 
"" {XPPMATH 20 "6#/\"%35*()-%!G6#\"\"#\"\"%\"\"\")-F(6#\"\"$F*F,-F(6#
\"\"(F," }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 57 "lcm(144,84)*gcd(
144,84)=ifactor(lcm(144,84)*gcd(144,84));" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#/\"&'47*()-%!G6#\"\"#\"\"'\"\"\")-F(6#\"\"$F0F,-F(6#\"
\"(F," }}}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 82 
"For the pair of numbers 2744280 and 267300 execute the following comm
and sequence:" }}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 49 "2744280=ifa
ctor(2744280);\n267300=ifactor(267300);" }}{PARA 11 "" 1 "" {XPPMATH 
20 "6#/\"(!GWF*,)-%!G6#\"\"#\"\"$\"\"\")-F(6#F+\"\"%F,-F(6#\"\"&F,-F(6
#\"\"(F,)-F(6#\"#6F*F," }}{PARA 11 "" 1 "" {XPPMATH 20 "6#/\"'+tE**)-%
!G6#\"\"#F*\"\"\")-F(6#\"\"$\"\"&F+)-F(6#F0F*F+-F(6#\"#6F+" }}}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 39 "2744280*267300=ifactor(2744280*2673
00);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#/\"-+S/YNt*,)-%!G6#\"\"#\"\"&
\"\"\")-F(6#\"\"$\"\"*F,)-F(6#F+F0F,-F(6#\"\"(F,)-F(6#\"#6F0F," }}}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 49 "gcd(2744280,267300)=ifactor(
gcd(2744280,267300));" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#/\"&?y\"**)-%
!G6#\"\"#F*\"\"\")-F(6#\"\"$\"\"%F+-F(6#\"\"&F+-F(6#\"#6F+" }}}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 49 "lcm(2744280,267300)=ifactor(lcm(274
