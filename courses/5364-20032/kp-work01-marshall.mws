F)-F&6#\"#8F)-F&6#\"#<F)" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 16 
"ifactor(38*865);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#**-%!G6#\"\"#\"\"
\"-F%6#\"\"&F(-F%6#\"#>F(-F%6#\"$t\"F(" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 13 "ifactor(10!);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#**)-
