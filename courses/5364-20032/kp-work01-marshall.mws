G" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 15 "isprime(10!+1);" }}
{PARA 11 "" 1 "" {XPPMATH 20 "6#%&falseG" }}}{PARA 0 "" 0 "" {TEXT -1 
0 "" }}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 16 "isprime(329891);" }}
{PARA 11 "" 1 "" {XPPMATH 20 "6#%%trueG" }}}{PARA 0 "" 0 "" {TEXT -1 
0 "" }}{PARA 0 "" 0 "" {TEXT -1 50 "Find all of the prime numbers betw
