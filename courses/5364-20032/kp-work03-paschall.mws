" }}}{PARA 0 "" 0 "" {TEXT -1 31 "Note:  it is possible to use a " }
{TEXT 263 9 "for loop " }{TEXT -1 69 " to simplify this task since we \+
are doing a repetitive calculation.  " }}{PARA 0 "" 0 "" {TEXT -1 29 "
Note:  Also, the the command " }{TEXT 265 6 "coeffs" }{TEXT -1 15 " un
fortunately " }{TEXT 266 8 "does not" }{TEXT -1 36 " pick off the coef
ficients in order." }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" 
{TEXT -1 4 "The " }{TEXT 259 16 "Binomial Theorem" }{TEXT -1 66 " give
s a formula for finding the coefficients of the expansion of " }
{XPPEDIT 18 0 "(a+b)^n;" "6#),&%\"aG\"\"\"%\"bGF&%\"nG" }{TEXT -1 10 "
  for any " }{TEXT 267 1 "n" }{TEXT -1 53 ".  It is relatively obvious
 that the coefficient of  " }{XPPEDIT 18 0 "a^(n-k)*b^k;" "6#*&)%\"aG,
&%\"nG\"\"\"%\"kG!\"\"F()%\"bGF)F(" }{TEXT -1 19 "  for any value of \+
" }{TEXT 268 1 "k" }{TEXT -1 11 " from 0 to " }{TEXT 269 1 "n" }{TEXT 
-1 46 " is given by the number of ways we can choose " }{TEXT 270 1 "k
" }{TEXT -1 8 " of the " }{TEXT 294 1 "b" }{TEXT -1 12 "'s from the " 
}{TEXT 271 1 "n" }{TEXT -1 1 " " }{TEXT 295 1 "b" }{TEXT -1 20 "'s in \+
the expansion " }{XPPEDIT 18 0 "(a+b)*(a+b)" "6#*&,&%\"aG\"\"\"%\"bGF&
F&,&F%F&F'F&F&" }{TEXT -1 7 " ....( " }{XPPEDIT 18 0 "(a+b)" "6#,&%\"a
G\"\"\"%\"bGF%" }{TEXT -1 5 " ),  " }{TEXT 272 1 "n" }{TEXT -1 41 " ti
mes .   The number of combinations of " }{TEXT 273 1 "n" }{TEXT -1 18 
" objects choosing " }{TEXT 274 1 "k" }{TEXT -1 12 " at a time, " }
{XPPEDIT 18 0 "nCk" "6#%$nCkG" }{TEXT -1 27 ", is given by the formula
  " }{XPPEDIT 18 0 "nCk=n!/(k!*(n-k)!)" "6#/%$nCkG*&-%*factorialG6#%\"
nG\"\"\"*&-F'6#%\"kGF*-F'6#,&F)F*F.!\"\"F*F2" }{TEXT -1 2 " ." }}
{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT 261 10 "State th
e " }{TEXT 260 16 "Binomial Theorem" }{TEXT -1 1 " " }{TEXT 275 31 "an
d use Maple to demonstrate it" }{TEXT -1 1 "." }}{PARA 0 "" 0 "" 
{TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 4 "The " }{TEXT 298 16 "Binom
ial Theorem" }{TEXT -1 66 " gives a formula for finding the coefficien
ts of the expansion of " }{XPPEDIT 18 0 "(a+b)^n;" "6#),&%\"aG\"\"\"%
\"bGF&%\"nG" }{TEXT -1 10 "  for any " }{TEXT 299 1 "n" }{TEXT -1 2 ".
(" }{TEXT 300 127 "This is copied from above) You can use Pascal's Tri
angle to express coefficients from the expanded statement (a+b)^n for \+
any n." }}{PARA 0 "" 0 "" {TEXT -1 8 "Compute " }{XPPEDIT 18 0 "sum(bi
nomial(n,k),k=0..n)" "6#-%$sumG6$-%)binomialG6$%\"nG%\"kG/F*;\"\"!F)" 
}{TEXT -1 34 "  for n=1 to 10.  Here the symbol " }{XPPEDIT 18 0 "Sigm
a;" "6#%&SigmaG" }{TEXT -1 70 " (Greek letter Sigma) stands for sum.  \+
 (See the worksheet SumSeq.mws)" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 79 "for n from 1 to 10 do Sum(bi
nomial(n,k), k=0..n)=sum(binomial (n,k),k=0..n);od;" }}{PARA 11 "" 1 "
" {XPPMATH 20 "6#/-%$SumG6$-%)binomialG6$\"\"\"%\"kG/F+;\"\"!F*\"\"#" 
}}{PARA 11 "" 1 "" {XPPMATH 20 "6#/-%$SumG6$-%)binomialG6$\"\"#%\"kG/F
+;\"\"!F*\"\"%" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#/-%$SumG6$-%)binomia
lG6$\"\"$%\"kG/F+;\"\"!F*\"\")" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#/-%$
SumG6$-%)binomialG6$\"\"%%\"kG/F+;\"\"!F*\"#;" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#/-%$SumG6$-%)binomialG6$\"\"&%\"kG/F+;\"\"!F*\"#K" }}
{PARA 11 "" 1 "" {XPPMATH 20 "6#/-%$SumG6$-%)binomialG6$\"\"'%\"kG/F+;
\"\"!F*\"#k" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#/-%$SumG6$-%)binomialG6
$\"\"(%\"kG/F+;\"\"!F*\"$G\"" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#/-%$Su
mG6$-%)binomialG6$\"\")%\"kG/F+;\"\"!F*\"$c#" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#/-%$SumG6$-%)binomialG6$\"\"*%\"kG/F+;\"\"!F*\"$7&" }}
{PARA 11 "" 1 "" {XPPMATH 20 "6#/-%$SumG6$-%)binomialG6$\"#5%\"kG/F+;
