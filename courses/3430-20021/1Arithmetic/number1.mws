{TEXT -1 6 "11.   " }{TEXT 259 61 "Explain the meaning of the term \"f
loating point arithematic.\"" }}{PARA 0 "" 0 "" {TEXT -1 80 "12.  Exec
ute the following command sequence and record any relevant observation
s" }}{EXCHG {PARA 0 "> " 0 "" {XPPEDIT 19 1 "convert(.3333333333333333
333,fraction);" "6#-%(convertG6$$\"4LLLLLLLLL$!#>%)fractionG" }}}
{EXCHG {PARA 0 "> " 0 "" {XPPEDIT 19 1 "convert(sqrt(2),fraction);" "6
#-%(convertG6$-%%sqrtG6#\"\"#%)fractionG" }}}{EXCHG {PARA 0 "> " 0 "" 
{XPPEDIT 19 1 "convert(evalf(sqrt(2)),fraction);" "6#-%(convertG6$-%&e
valfG6#-%%sqrtG6#\"\"#%)fractionG" }}}{PARA 0 "" 0 "" {TEXT -1 0 "" }}
{PARA 0 "" 0 "" {TEXT -1 5 "12.  " }{TEXT 260 46 "This last response i
s very misleading.  Why?  " }}{PARA 0 "" 0 "" {TEXT -1 58 "13.  Experi
ment with several examples to determine if the " }{TEXT 256 7 "command
" }{TEXT 261 29 " convert(expression,fraction)" }{TEXT -1 68 "  is an \+
\"exact operation\" or some sort of \"approximate operation.\"  " }
{TEXT 265 13 "Which is it? " }{TEXT -1 25 "     Show your examples ." 
}}{PARA 0 "" 0 "" {TEXT -1 24 "14.  Continue as before." }}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 3 "Pi;" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 12 "Digits:=100;" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 
0 10 "evalf(Pi);" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 20 "convert
