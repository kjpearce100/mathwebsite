{PARA 0 "> " 0 "" {XPPEDIT 19 1 "lcm(5*(1+4^3),2^5);" "6#-%$lcmG6$*&\"
\"&\"\"\",&F(F(*$\"\"%\"\"$F(F(*$\"\"#F'" }}}{EXCHG {PARA 0 "> " 0 "" 
{XPPEDIT 19 1 "36/gcd(36,16);" "6#*&\"#O\"\"\"-%$gcdG6$F$\"#;!\"\"" }}
}{EXCHG {PARA 0 "> " 0 "" {XPPEDIT 19 1 "lcm(38,100)/gcd(38,100);" "6#
*&-%$lcmG6$\"#Q\"$+\"\"\"\"-%$gcdG6$F'F(!\"\"" }}}{EXCHG {PARA 0 "> " 
0 "" {XPPEDIT 19 1 "lcm(1524,5587);" "6#-%$lcmG6$\"%C:\"%(e&" }}}
