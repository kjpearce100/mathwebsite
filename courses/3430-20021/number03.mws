{TEXT 267 1 " " }{TEXT -1 32 "and use MAPLE to demonstrate it." }}
{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 15 "4.  Compu
te    " }{XPPEDIT 18 0 "sum(binomial(n,k),k=0..n)" "6#-%$sumG6$-%)bino
mialG6$%\"nG%\"kG/F*;\"\"!F)" }{TEXT -1 16 "  for n=1 to 10." }}{PARA 
0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 4 "5.  " }{TEXT 
