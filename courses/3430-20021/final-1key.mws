0 "" 0 "" {TEXT -1 100 "I-9.  (10 points)  Find the general (real-valu
ed) solution of the system of differential equations  " }{XPPEDIT 19 
1 "\{diff(x[1](t),t) = -x[1](t)+2*x[2](t), diff(x[2](t),t) = -2*x[1](t
)-3*x[2](t)\};" "6#<$/-%%diffG6$-&%\"xG6#\"\"\"6#%\"tGF.,&-&F*6#F,6#F.
!\"\"*&\"\"#F,-&F*6#F66#F.F,F,/-F&6$-&F*6#F66#F.F.,&*&F6F,-&F*6#F,6#F.
F,F4*&\"\"$F,-&F*6#F66#F.F,F4" }}{PARA 0 "" 0 "" {TEXT -1 3 "   " }}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 33 "M := matrix([ [-1, 2],[-2,-3
] ]);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%\"MG-%'matrixG6#7$7$!\"\"\"
\"#7$!\"#!\"$" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 14 "eigenvects
(M);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6$7%,&\"\"#!\"\"*&\"\"$#\"\"\"F%
^#F*F*F*F*<#-%'vectorG6#7$F*,&#F*F%F&*&^#F)F*F(F)F*7%,&F%F&*&^#F&F*F(F
)F*F*<#-F.6#7$F*,&#F*F%F&*&^##F&F%F*F(F)F*" }}}{EXCHG {PARA 0 "> " 0 "
" {MPLTEXT 1 0 46 "E := matrix(2,1,[1, -1/2 + I*(1/2)*sqrt(3)] );" }}
{PARA 11 "" 1 "" {XPPMATH 20 "6#>%\"EG-%'matrixG6#7$7#\"\"\"7#,&#F*\"
\"#!\"\"*&^##F*F.F*\"\"$F2F*" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 
0 63 "G := (1/2)*(E + conjugate(E)); H := (1/2)*I*(E - conjugate(E));
" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%\"GG,&*&\"\"#!\"\"%\"EG\"\"\"F**
&#F*F'F*-%*conjugateG6#F)F*F*" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%\"H
G*&^##\"\"\"\"\"#F(,&%\"EGF(-%*conjugateG6#F+!\"\"F(" }}}{EXCHG {PARA 
0 "> " 0 "" {MPLTEXT 1 0 18 "evalm(G);evalm(H);" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#-%'matrixG6#7$7#\"\"\"7##!\"\"\"\"#" }}{PARA 11 "" 1 "
" {XPPMATH 20 "6#-%'matrixG6#7$7#\"\"!7#,$*&\"\"#!\"\"\"\"$#\"\"\"F,F-
" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 121 "XX := exp(-2*t)*c[1]*(
G*cos(sqrt(3)*t) + H*sin(sqrt(3)*t)) + \n      exp(-2*t)*c[2]*(H*cos(s
qrt(3)*t) - G*sin(sqrt(3)*t));" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#X
XG,&*(-%$expG6#,$*&\"\"#\"\"\"%\"tGF-!\"\"F-&%\"cG6#F-F-,&*&,&*&F,F/%
\"EGF-F-*&#F-F,F--%*conjugateG6#F7F-F-F--%$cosG6#*&\"\"$F9F.F-F-F-*(^#
F9F-,&F7F-F:F/F--%$sinGF?F-F-F-F-*(F'F-&F16#F,F-,&*(FCF-FDF-F=F-F-*&F5
F-FEF-F/F-F-" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 33 "evalm(map(d
iff,XX,t)-`&*`(M,XX));" }}{PARA 12 "" 1 "" {XPPMATH 20 "6#-%'matrixG6#
7$7#,.*(-%$expG6#,$*&\"\"#\"\"\"%\"tGF0!\"\"F0&%\"cG6#F0F0-%$cosG6#*&
\"\"$#F0F/F1F0F0F2**F*F0F3F0-%$sinGF8F0F:F;F2*(F*F0&F46#F/F0F=F0F0**F*
F0F@F0F6F0F:F;F2**F/F0F*F0F3F0,&*&#F0F/F0F6F0F2*&#F0F/F0*&F=F0F:F;F0F2
F0F2**F/F0F*F0F@F0,&*&#F0F/F0*&F6F0F:F;F0F2*&F;F0F=F0F0F0F27#,.*(F*F0F
3F0FDF0F0*(F*F0F3F0,&*&F;F0FIF0F0*&#F:F/F0F6F0F2F0F0*(F*F0F@F0FKF0F0*(
F*F0F@F0,&*&#F:F/F0F=F0F0*&F;F0FNF0F0F0F0**F/F0F*F0F3F0F6F0F0**F/F0F*F
