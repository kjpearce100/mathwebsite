{MPLTEXT 1 0 28 "int(int(x*y+x^3-y^2+2,y),x);" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#,**&#\"\"\"\"\"%F&*&)%\"xG\"\"#F&)%\"yGF+F&F&F&*&F%F&*&
