{TEXT -1 73 "III.  Use Maple to find all of the intersection points of
 the graphs of  " }{XPPEDIT 18 0 "y = x^3-2*x" "6#/%\"yG,&*$%\"xG\"\"$
\"\"\"*&\"\"#F)F'F)!\"\"" }{TEXT -1 8 "   and  " }{XPPEDIT 18 0 "y = 2
*cos(x)" "6#/%\"yG*&\"\"#\"\"\"-%$cosG6#%\"xGF'" }}{EXCHG {PARA 0 "> \+
" 0 "" {MPLTEXT 1 0 30 "f := x^3 - 2*x; g := 2*cos(x);" }}{PARA 11 "" 
1 "" {XPPMATH 20 "6#>%\"fG,&*$)%\"xG\"\"$\"\"\"F**&\"\"#F*F(F*!\"\"" }
}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%\"gG,$-%$cosG6#%\"xG\"\"#" }}}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 91 "plot([f,g],x=-5..5,y=-5..5);
\nplot([f,g],x=-2..0,y=0..2);\nplot([f,g],x=-1.5..-0.5,y=0.5..1);" }}
