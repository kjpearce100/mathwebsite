f(%);" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 11 "Digits:=10;" }}}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 10 "sqrt(2)/3;" }}}{EXCHG {PARA 
0 "> " 0 "" {MPLTEXT 1 0 9 "evalf(%);" }}}{PARA 0 "" 0 "" {TEXT -1 7 "
       " }}{PARA 0 "" 0 "" {TEXT -1 1 " " }{TEXT 258 90 "If eval is sh
ort for \"evaluate\" what do you think the \"f\" in the command evalf \+
