\"\"F*F*\"\"'7&F*\"\"#\"\"$\"#57&F*F-%\"aG%\"bG" }}}{EXCHG {PARA 0 "> \+
" 0 "" {MPLTEXT 1 0 13 "gausselim(B);" }}{PARA 11 "" 1 "" {XPPMATH 20 
"6#-%'matrixG6#7%7&\"\"\"F(F(\"\"'7&\"\"!F(\"\"#\"\"%7&F+F+,&%\"aGF(\"
\"$!\"\",&%\"bGF(\"#5F2" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 11 "
backsub(%);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#-%'vectorG6#7%*&,(%\"aG
\"\"#\"#;!\"\"%\"bG\"\"\"F.,&F)F.\"\"$F,F,,$*&,(F)F*\"\"%F.F-F,F.F/F,F
**&,&F-F.\"#5F,F.F/F," }}}{PARA 0 "" 0 "" {TEXT -1 19 "Unique solution
 at " }{XPPEDIT 18 0 "a<>3" "6#0%\"aG\"\"$" }{TEXT -1 4 " .  " }}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 45 "B3:=matrix([[1,1,1,6],[1,2,3
,10],[1,2,3,b]]);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#B3G-%'matrixG6
