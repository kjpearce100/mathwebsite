{SECT 0 {PARA 260 "" 0 "" {TEXT -1 22 "MAPLE Practice Quiz 7+" }}
{PARA 0 "" 0 "" {TEXT -1 106 "1. Solve the following linear system by \+
using row reduction and back substitution on its augmented matrix:" }}
{PARA 256 "" 0 "" {XPPEDIT 18 0 "2*x[1]+3*x[2]+4*x[3]+5*x[4]+6*x[5]+7*
x[6]=8" "6#/,.*&\"\"#\"\"\"&%\"xG6#F'F'F'*&\"\"$F'&F)6#F&F'F'*&\"\"%F'
&F)6#F,F'F'*&\"\"&F'&F)6#F0F'F'*&\"\"'F'&F)6#F4F'F'*&\"\"(F'&F)6#F8F'F
'\"\")" }}{PARA 257 "" 0 "" {XPPEDIT 18 0 "3*x[1]+3*x[2]+4*x[3]+5*x[4]
+6*x[5]+7*x[6]=11" "6#/,.*&\"\"$\"\"\"&%\"xG6#F'F'F'*&F&F'&F)6#\"\"#F'
F'*&\"\"%F'&F)6#F&F'F'*&\"\"&F'&F)6#F0F'F'*&\"\"'F'&F)6#F4F'F'*&\"\"(F
'&F)6#F8F'F'\"#6" }}{PARA 258 "" 0 "" {XPPEDIT 18 0 "4*x[1]+4*x[2]+4*x
[3]+5*x[4]+6*x[5]+7*x[6]=37" "6#/,.*&\"\"%\"\"\"&%\"xG6#F'F'F'*&F&F'&F
)6#\"\"#F'F'*&F&F'&F)6#\"\"$F'F'*&\"\"&F'&F)6#F&F'F'*&\"\"'F'&F)6#F4F'
F'*&\"\"(F'&F)6#F8F'F'\"#P" }}{PARA 259 "" 0 "" {XPPEDIT 18 0 "5*x[1]+
5*x[2]+5*x[3]+5*x[4]+6*x[5]+7*x[6]=32" "6#/,.*&\"\"&\"\"\"&%\"xG6#F'F'
F'*&F&F'&F)6#\"\"#F'F'*&F&F'&F)6#\"\"$F'F'*&F&F'&F)6#\"\"%F'F'*&\"\"'F
'&F)6#F&F'F'*&\"\"(F'&F)6#F8F'F'\"#K" }}{PARA 0 "" 0 "" {TEXT -1 45 "R
epeat the exercise with the rhs all equal 0." }}{EXCHG {PARA 0 "> " 0 
"" {MPLTEXT 1 0 13 "with(linalg):" }}{PARA 7 "" 1 "" {TEXT -1 80 "Warn
ing, the protected names norm and trace have been redefined and unprot
ected\n" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 80 "A:=matrix([[2,3,
4,5,6,7,8],[3,3,4,5,6,7,11],[4,4,4,5,6,7,37],[5,5,5,5,6,7,32]]);" }}
{PARA 11 "" 1 "" {XPPMATH 20 "6#>%\"AG-%'matrixG6#7&7)\"\"#\"\"$\"\"%
\"\"&\"\"'\"\"(\"\")7)F+F+F,F-F.F/\"#67)F,F,F,F-F.F/\"#P7)F-F-F-F-F.F/
\"#K" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 12 "RA:=rref(A);" }}
{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#RAG-%'matrixG6#7&7)\"\"\"\"\"!F+F+F
+F+\"\"$7)F+F*F+F+F+F+\"#B7)F+F+F*F+F+F+!#J7)F+F+F+F*#\"\"'\"\"&#\"\"(
F4#\"#dF4" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 12 "backsub(RA);" 
}}{PARA 11 "" 1 "" {XPPMATH 20 "6#-%'vectorG6#7(\"\"$\"#B!#J,(#\"#d\"
\"&\"\"\"*&#\"\"'F-F.&%#_tG6#\"\"#F.!\"\"*&#\"\"(F-F.&F36#F.F.F6F2F:" 
}}}{PARA 0 "" 0 "" {XPPEDIT 18 0 "x[1] = 3,x[2] = 23,x[3] = -31,x[4] =
 57/5-6*x[5]/5/5-7*x[6]/5;" "6&/&%\"xG6#\"\"\"\"\"$/&F%6#\"\"#\"#B/&F%
6#F(,$\"#J!\"\"/&F%6#\"\"%,(*&\"#dF'\"\"&F3F'**\"\"'F'&F%6#F;F'F;F3F;F
3F3*(\"\"(F'&F%6#F=F'F;F3F3" }}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 
106 "A0:= matrix([[2, 3, 4, 5, 6, 7, 0], [3, 3, 4, 5, 6, 7, 0], [4, 4,
 4, 5, 6, 7, 0], [5, 5, 5, 5, 6, 7, 0]]);" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#>%#A0G-%'matrixG6#7&7)\"\"#\"\"$\"\"%\"\"&\"\"'\"\"(\"
