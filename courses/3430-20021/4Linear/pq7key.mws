0 "> " 0 "" {MPLTEXT 1 0 9 "rref(A0);" }}{PARA 11 "" 1 "" {XPPMATH 20 
"6#-%'matrixG6#7&7)\"\"\"\"\"!F)F)F)F)F)7)F)F(F)F)F)F)F)7)F)F)F(F)F)F)
F)7)F)F)F)F(#\"\"'\"\"&#\"\"(F/F)" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 11 "backsub(%);" }{TEXT -1 0 "" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#-%'vectorG6#7(\"\"!F'F',&&%#_tG6#\"\"##!\"'\"\"&*&#\"\"
