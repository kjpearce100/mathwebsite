\"\"\"F(*&\"\"#F(&F&6#F*F(F(*&%\"aGF(&F&6#\"\"$F(F(%\"bG" }}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 44 "B:=matrix([[1,1,1,6],[1,2,3,10],[1,
