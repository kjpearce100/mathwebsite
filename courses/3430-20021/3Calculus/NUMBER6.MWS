{TEXT -1 9 "Continue." }}{EXCHG {PARA 0 "> " 0 "" {XPPEDIT 19 1 "f6:=p
iecewise(x=0,0,x*sin(1/x));" "6#>%#f6G-%*piecewiseG6%/%\"xG\"\"!F**&F)
\"\"\"-%$sinG6#*&F,F,F)!\"\"F," }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 
1 0 13 "subs(x=0,f6);" }}}{EXCHG {PARA 0 "> " 0 "" {XPPEDIT 19 1 "limi
t(f6,x=0);" "6#-%&limitG6$%#f6G/%\"xG\"\"!" }}}{PARA 0 "" 0 "" {TEXT 
-1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 61 "     b.  On the plot of f6 incl
ude the graphs of the lines   " }{XPPEDIT 18 0 "y=x" "6#/%\"yG%\"xG" }
{TEXT -1 5 " and " }{XPPEDIT 18 0 "y=-x" "6#/%\"yG,$%\"xG!\"\"" }
{TEXT -1 1 "." }}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 0 "" }}}{PARA 
0 "" 0 "" {TEXT -1 9 "Continue." }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}
{EXCHG {PARA 0 "> " 0 "" {XPPEDIT 19 1 "f7:=piecewise(x=0,0,x^2*sin(1/
x));" "6#>%#f7G-%*piecewiseG6%/%\"xG\"\"!F**&F)\"\"#-%$sinG6#*&\"\"\"F
1F)!\"\"F1" }}}{EXCHG {PARA 0 "> " 0 "" {XPPEDIT 19 1 "limit(f7,x=0);
" "6#-%&limitG6$%#f7G/%\"xG\"\"!" }}}{PARA 0 "" 0 "" {TEXT -1 65 "    \+
  c.  On the plot of f7 include the graphs of the parabolas  " }
{XPPEDIT 18 0 "  y=x^2   " "6#/%\"yG*$%\"xG\"\"#" }{TEXT -1 5 " and " 
}{XPPEDIT 18 0 "y=-x^2  " "6#/%\"yG,$*$%\"xG\"\"#!\"\"" }{TEXT -1 2 " \+
." }}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 0 "" }}}{PARA 0 "" 0 "" 
{TEXT -1 83 "Execute the following command sequences.  They are intend
ed to indicate more of the" }}{PARA 0 "" 0 "" {TEXT -1 32 "MAPLE compu
ter algebra features." }}{EXCHG {PARA 0 "> " 0 "" {XPPEDIT 19 1 "f8:= \+
(a*x^3+c*x^2-1)/(b*x^3-2);" "6#>%#f8G*&,(*&%\"aG\"\"\"*$%\"xG\"\"$F)F)
*&%\"cGF)*$F+\"\"#F)F)F)!\"\"F),&*&%\"bGF)*$F+F,F)F)F0F1F1" }}}{EXCHG 
{PARA 0 "> " 0 "" {XPPEDIT 19 1 "subs(x=1,f8);" "6#-%%subsG6$/%\"xG\"
\"\"%#f8G" }}}{EXCHG {PARA 0 "> " 0 "" {XPPEDIT 19 1 "limit(f8,x=1);" 
