{TEXT -1 1 " " }}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 0 "" }}}{PARA 
0 "" 0 "" {TEXT -1 0 "" }{TEXT 259 12 "Explanation." }}{PARA 0 "" 0 "
" {TEXT -1 4 "    " }}{PARA 0 "" 0 "" {TEXT -1 100 "Continue. First gr
