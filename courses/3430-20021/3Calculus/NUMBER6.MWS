19 1 "limit(f8,x=infinity);" "6#-%&limitG6$%#f8G/%\"xG%)infinityG" }}}
{EXCHG {PARA 0 "> " 0 "" {XPPEDIT 19 1 "f9:=subs(a=0,f8);" "6#>%#f9G-%
%subsG6$/%\"aG\"\"!%#f8G" }}}{EXCHG {PARA 0 "> " 0 "" {XPPEDIT 19 1 "l
imit(f9,x=infinity);" "6#-%&limitG6$%#f9G/%\"xG%)infinityG" }}}{EXCHG 
{PARA 0 "> " 0 "" {XPPEDIT 19 1 "f10:=subs(b=0,f8);" "6#>%$f10G-%%subs
G6$/%\"bG\"\"!%#f8G" }}}{EXCHG {PARA 0 "> " 0 "" {XPPEDIT 19 1 "limit(
f10,x=infinity);" "6#-%&limitG6$%$f10G/%\"xG%)infinityG" }}}{PARA 0 "
" 0 "" {TEXT -1 49 "3.  Experiment with the function  signum(x)  and \+
