{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 0 "> " 0 "
" {XPPEDIT 19 1 "limit(f12,x=0);" "6#-%&limitG6$%$f12G/%\"xG\"\"!" }}}
