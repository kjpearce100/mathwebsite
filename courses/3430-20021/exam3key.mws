FFF/FFF1F/,$*(F2F-FFF/FFF1F/,$*(\"\"$F-FFF/FFF1F/,$*(F>F-FFF/FFF1F/" }
}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 111 "for i from 1 to 4 do\nfor
 j from 1 to 2 do\nprint(BNS[i],`dot`,BCS[j],`value is`,dotprod(BNS[i]
