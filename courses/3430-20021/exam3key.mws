vectorG6#7(,$*(\"\"#\"\"\"\"$0\"!\"\"\"$5##F*F)F*,$*&F-F,F-F.F*,$*&F+F
,F-F.F,,$*&\"#UF,F-F.F,,$*(\"\"%F*F+F,F-F.F,,$*&\"#@F,F-F.F*%$dotG-F$6
