#8F*FDF,FDF.F*,$*(F8F*FDF,FDF.F*,$*&FCF,FDF.F,%)value~isG\"\"!" }}
{PARA 11 "" 1 "" {XPPMATH 20 "6'-%'vectorG6#7(,$*(\"\"#\"\"\"\"$0\"!\"
