{SECT 0 {PARA 256 "" 0 "" {TEXT -1 16 "Practice Quize 3" }}{PARA 0 "" 
0 "" {TEXT -1 125 "1.  Use the graphing feature of MAPLE to demonstrat
e that the graph of an odd degree polynomial must always cross the x-a
xis." }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 31 "2
.  Find the value of M so that" }}{PARA 0 "" 0 "" {TEXT -1 22 "     If
  m>M then     " }{XPPEDIT 18 0 "r=2*x^2+5*x+m" "6#/%\"rG,(*&\"\"#\"\"
\"*$%\"xGF'F(F(*&\"\"&F(F*F(F(%\"mGF(" }{TEXT -1 21 "   has no real ro
ots." }}{PARA 0 "" 0 "" {TEXT -1 21 "     If m=M then     " }{XPPEDIT 
18 0 "r=2*x^2+5*x+m" "6#/%\"rG,(*&\"\"#\"\"\"*$%\"xGF'F(F(*&\"\"&F(F*F
(F(%\"mGF(" }{TEXT -1 22 "    has one real root." }}{PARA 0 "" 0 "" 
{TEXT -1 21 "     If m<M then     " }{XPPEDIT 18 0 "r=2*x^2+5*x+m" "6#
/%\"rG,(*&\"\"#\"\"\"*$%\"xGF'F(F(*&\"\"&F(F*F(F(%\"mGF(" }{TEXT -1 
22 "   has two real roots." }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 
"" 0 "" {TEXT -1 66 "3.  Provide a nice smooth looking graph for each \+
of the following:" }}{PARA 0 "" 0 "" {TEXT -1 2 "a." }}{EXCHG {PARA 0 
