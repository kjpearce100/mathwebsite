\"yGF3F'F'F'F'-%$expG6#,&*$F2F3!\"\"*$F5F3F;F'" }}}{PARA 0 "" 0 "" 
{TEXT -1 1 " " }}{PARA 0 "" 0 "" {TEXT -1 14 "b.            " }}
{EXCHG {PARA 0 "> " 0 "" {XPPEDIT 19 1 " -x^2+2*y^2+z^2 = 1;" "6#/,(*$
%\"xG\"\"#!\"\"*&F'\"\"\"*$%\"yGF'F*F**$%\"zGF'F*F*" }}}{PARA 0 "" 0 "
