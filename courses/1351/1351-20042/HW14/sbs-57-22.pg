TEXT(&beginproblem);
$showPartialCorrectAnswers = 1;

$pi = 3.14159265;
$e= 2.718281828;
 

BEGIN_TEXT 
$BR
This is problem 22 Section 5.7 page 333. $BR $BR

 
Find the average value of  \(f(x) = 2\sin(x)-\cos(x)\) on \([0,\pi/2]\)

  $BR$BR

  $SPACE Average Value \(\displaystyle     = \) 
 $SPACE        \{ans_rule(40) \}    
 $BR$BR

 
$PAR
END_TEXT
 

$ans1 ="2/$pi";
&ANS(std_num_cmp($ans1));

  
  

