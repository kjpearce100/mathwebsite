to branches  :l 
seth 90 fd :l
repeat 8-1 [rt 180- (((8-2)*180)/8) fd :l]
pu home pd
limpoly  :l 
end

to door :width :height :startx :starty :knobx :knoby :radius
rectangle :width :height :startx :starty
pu setxy :knobx :knoby pd arc 360 :radius
end

