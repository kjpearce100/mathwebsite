to traingle :base :height :x :y
pu setxy :x :y pd
fd :base rt 180-(90+(2*((1/2)*:base)/:height)) fd ((1/2)*:base+:height) rt 180-(2*((1/2)*:base)/:height) fd ((1/2)*:base+:height)
end

to tree
rectangle 25 125 -400 -200
pu setxy -412 40 pd 
branches 50 
pu home pd
end

to triangle :base :height :x :y
pu setxy :x :y pd
setxy :x+:base :y
setxy :x+(1/2)*:base :y+:height
setxy :x :y
end

