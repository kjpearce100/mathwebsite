to housedoor
door 100 100 150 0 230 45 5
setfloodcolor [255 255 0] fill
lt 55 pu fd 9 pd 
setfloodcolor [0 255 0] fill
pu home pd
end

to limpoly :n :l :m
seth 90 fd :l
repeat :n-1 [rt 180- (((:n-2)*180)/:n) fd :l]
pu home pd
if :n>:m [stop]
limpoly :n+1 :l :m
end

to limstar :n :l :m
home
nstar :n :l
if :n>:m [stop] 
limstar :n+2 :l :m
end

to maze :l :a :m
fd :l rt 90
if :l>:m[stop]
maze :l+:a :a :m 
end

to moon
pu home
setxy 400 400 pd
arc 360 60
setfloodcolor [183 183 183] fill
setpencolor 7
arc 360 60
pu setxy 440 410 pd
arc 360 60
setfloodcolor [255 255 255] fill
setpencolor 0
nstar 5 20
pu lt 75 fd 10 pd
nstar 5 20
pu rt 80 fd 16 pd
nstar 5 20
pu home pd
end

to myname :x :y
setxy :x :y 
label "Meredith
end

to npoly :n
setxy -100 0
rt 90 fd 100
repeat :n-1 [rt 180- (((:n-2)*180)/:n) fd 100]
home
end

to nstar :n :l
fd :l
repeat :n-1 [rt 180-(180-((180-((:n-2)*(180/:n)))*2)) fd :l]
end

to nstar2 :n
fd 75	
repeat :n-1 [rt (3*(360/:n))fd 75]
home
end

to nstarh :n :l
seth 90
fd :l
repeat :n-1 [rt 180-(180-((180-((:n-2)*(180/:n)))*2)) fd :l]
pu home pd
end

