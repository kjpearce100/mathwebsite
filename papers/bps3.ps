1 setlinejoin
1 setlinecap
0.0 setgray
/inch {72 mul} def
/fheight 0.35 inch neg def
    0 G
medium setlinewidth
[] 0 setdash defaultFont
userFont1
% bug patch -- we have a problem
defaultFont
