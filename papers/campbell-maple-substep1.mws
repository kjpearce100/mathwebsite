o that we can pick off the real part of " }{TEXT 261 2 "fr" }{TEXT -1 
8 " and of " }{TEXT 262 2 "ft" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 41 "frs := subs(I=y,fr);\nfts :=
 subs(I=y,ft);" }}{PARA 12 "" 1 "" {XPPMATH 20 "6#>%$frsG,>*,\"\"'\"\"
