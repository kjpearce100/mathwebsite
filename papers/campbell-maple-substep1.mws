F0F(F(**F+F(F6F(F8F()F,F5F(F(**F+F(F6F(F8F()F2F5F(F(*(F+F(F0F(F,F(F(*,
F;F(F)F(F0F(F9F(F2F(F(" }}{PARA 12 "" 1 "" {XPPMATH 20 "6#>%#ftG,>*,^#
\"\"'\"\"\")%\"rG\"\"$F)-%$cosG6#%&thetaGF)%\"aGF))-%$sinGF/\"\"#F)F)*
,^#\"\"%F))F1F5F))F+F8F))F-F5F)F2F)F)**F5F)F*F))F3F,F)F1F)!\"\"**F5F)F
1F)F+F)F3F)F>**^#F5F)F9F))F+F5F)F;F)F)**^#!\"#F)F9F)FBF)F2F)F)*(F7F)FB
F)F;F)F)*(F7F)FBF)F2F)F)*,F8F)F9F)FBF)F-F)F3F)F>**F'F)F*F))F-F,F)F1F)F
)**FAF)F9F)F:F))F-F8F)F)**FAF)F9F)F:F))F3F8F)F)**FAF)F1F)F+F)F-F)F)*,F
5F)F*F)F;F)F1F)F3F)F>" }}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}
{PARA 0 "" 0 "" {TEXT -1 37 "We temporarily substitute a variable " }
