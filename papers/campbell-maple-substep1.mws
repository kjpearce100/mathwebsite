3 "   " }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 47 
"The denomimator of each partial derivative is  " }{XPPEDIT 18 0 "abs(
FF);" "6#-%$absG6#%#FFG" }}{PARA 0 "" 0 "" {TEXT -1 1 " " }}}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 70 "fr := expand(FFc*(2*c+2*a*c^2)/r);
\nft := expand(FFc*I*(2*c+2*a*c^2));\n" }}{PARA 12 "" 1 "" {XPPMATH 
20 "6#>%#frG,>*,\"\"'\"\"\")%\"rG\"\"#F(-%$cosG6#%&thetaGF(%\"aGF()-%$
