{SECT 0 {EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT 
-1 92 "file:  campbell-maple-substep1.mws -- verify that H(c,x,a) has \+
no local extreme point on O_r" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 8 "restart;" }}}{EXCHG {PARA 0 "
" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 7 "Define " }{XPPEDIT 
311 0 "m = m(alpha);" "6#/%\"mG-F$6#%&alphaG" }{TEXT -1 84 "  which is
 the bound on the radius of majorization specified in Campbell's Theor
em 2" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 37 "m := alpha+1 - sqrt(alpha^2+2*alpha);" }}{PARA 11 "" 
1 "" {XPPMATH 20 "6#>%\"mG,(%&alphaG\"\"\"F'F'*$,&*$)F&\"\"#F'F'*&F,F'
F&F'F'#F'F,!\"\"" }}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "
" 0 "" {TEXT -1 16 "Define the left " }{XPPEDIT 18 0 "l[1] = l[1](alph
a);" "6#/&%\"lG6#\"\"\"-&F%6#F'6#%&alphaG" }{TEXT -1 11 " and right " 
}{XPPEDIT 18 0 "l[2] = l[2](alpha);" "6#/&%\"lG6#\"\"#-&F%6#F'6#%&alph
aG" }{TEXT -1 33 " sides of the critical trapezoid " }{TEXT 256 1 "T" 
}{TEXT -1 1 " " }}{PARA 0 "" 0 "" {TEXT -1 5 "     " }}}{EXCHG {PARA 
0 "> " 0 "" {MPLTEXT 1 0 41 "l1 := (alpha-1)/5;\nl2 := (2-alpha)/(5/2)
;" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#l1G,&*&\"\"&!\"\"%&alphaG\"\"
\"F*#F*F'F(" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#l2G,&#\"\"%\"\"&\"\"
\"*(\"\"#F)F(!\"\"%&alphaGF)F," }}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "
" }}{PARA 0 "" 0 "" {TEXT -1 30 "We define below the functions " }
{TEXT 289 17 "F, E, D, C, B, H " }{TEXT -1 16 " (functions of  " }
{TEXT 332 7 "c, x, a" }{TEXT -1 81 " ) which arise in the formulation \+
of the basic inequality in line (4) and page 4." }}{PARA 0 "" 0 "" 
{TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 102 "Note, for convenience in
 this worksheet each such function is represented as a (capital) DOUBL
E letter" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 
101 "Note further, for each such XX the function XXc will be construct
ed to be the complex conjugate of XX" }}{PARA 0 "" 0 "" {TEXT -1 0 "" 
}}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 74 "FF := a + 2*c + a*c^2;\nF
Fc := a + 2*cc + a*cc^2;\nfff := (x^2-r^2)*(1-a^2);" }}{PARA 11 "" 1 "
" {XPPMATH 20 "6#>%#FFG,(%\"aG\"\"\"*&\"\"#F'%\"cGF'F'*&F&F')F*F)F'F'
" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%$FFcG,(%\"aG\"\"\"*&\"\"#F'%#ccG
F'F'*&F&F')F*F)F'F'" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%$fffG*&,&*$)%
\"xG\"\"#\"\"\"F+*$)%\"rGF*F+!\"\"F+,&F+F+*$)%\"aGF*F+F/F+" }}}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 23 "EE := 1-c;\nEEc := 1-cc;" }}{PARA 
11 "" 1 "" {XPPMATH 20 "6#>%#EEG,&\"\"\"F&%\"cG!\"\"" }}{PARA 11 "" 1 
"" {XPPMATH 20 "6#>%$EEcG,&\"\"\"F&%#ccG!\"\"" }}}{EXCHG {PARA 0 "> " 
0 "" {MPLTEXT 1 0 56 "DD := 1 + a*c - x^2*(a+c);\nDDc := 1 + a*cc - x^
2*(a+cc);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#DDG,(\"\"\"F&*&%\"aGF&
%\"cGF&F&*&)%\"xG\"\"#F&,&F(F&F)F&F&!\"\"" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#>%$DDcG,(\"\"\"F&*&%\"aGF&%#ccGF&F&*&)%\"xG\"\"#F&,&F(F
&F)F&F&!\"\"" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 58 "CC := abs(F
F)*(1-x^2)+fff;\nBB := abs(DD)-x*(1-a)*abs(EE);\n" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#>%#CCG,&*&-%$absG6#,(%\"aG\"\"\"*&\"\"#F,%\"cGF,F,*&F+F
,)F/F.F,F,F,,&F,F,*$)%\"xGF.F,!\"\"F,F,*&,&F3F,*$)%\"rGF.F,F6F,,&F,F,*
$)F+F.F,F6F,F," }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#BBG,&-%$absG6#,(
\"\"\"!\"\"*&%\"aGF*%\"cGF*F+*&)%\"xG\"\"#F*,&F-F*F.F*F*F*F**(F1F*,&F*
F*F-F+F*-F'6#,&F.F*F*F+F*F+" }}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }
}{PARA 0 "" 0 "" {TEXT -1 55 "Note, technically, HH should be multipli
ed by a factor " }{XPPEDIT 18 0 "1-x^2;" "6#,&\"\"\"F$*$%\"xG\"\"#!\"
\"" }{TEXT -1 12 ", but since " }{TEXT 294 1 "x" }{TEXT -1 112 " is fi
xed for the arguments in this substep of Step 3, this factor has been \+
dropped in this particular worksheet" }}{PARA 0 "" 0 "" {TEXT -1 4 "  \+
  " }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 15 "HH := CC/BB^2;\n" }}
{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#HHG*&,&*&-%$absG6#,(%\"aG\"\"\"*&\"
\"#F-%\"cGF-F-*&F,F-)F0F/F-F-F-,&F-F-*$)%\"xGF/F-!\"\"F-F-*&,&F4F-*$)%
\"rGF/F-F7F-,&F-F-*$)F,F/F-F7F-F-F-,&-F)6#,(F-F7*&F,F-F0F-F7*&F5F-,&F,
F-F0F-F-F-F-*(F6F-,&F-F-F,F7F--F)6#,&F0F-F-F7F-F7!\"#" }}}{EXCHG 
{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 40 "We introd
uce here the complex parameter " }{XPPEDIT 18 0 "c = re^(i*theta);" "6
#/%\"cG)%#reG*&%\"iG\"\"\"%&thetaGF)" }{TEXT -1 28 "  and its complex \+
conjugate " }{XPPEDIT 18 0 "cc = re^(-i*theta);" "6#/%#ccG)%#reG,$*&%
\"iG\"\"\"%&thetaGF*!\"\"" }{TEXT -1 2 "  " }}{PARA 0 "" 0 "" {TEXT 
-1 3 "   " }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 72 "c := r*(cos(th
eta) + I*sin(theta));\ncc := r*(cos(theta) - I*sin(theta));" }}{PARA 
11 "" 1 "" {XPPMATH 20 "6#>%\"cG*&%\"rG\"\"\",&-%$cosG6#%&thetaGF'*&-%
$sinGF+F'^#F'F'F'F'" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#ccG*&%\"rG\"
\"\",&-%$cosG6#%&thetaGF'*&^#!\"\"F'-%$sinGF+F'F'F'" }}}{EXCHG {PARA 
0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 23 "We introduce fu
nctions " }{TEXT 312 2 "fr" }{TEXT -1 5 " and " }{TEXT 313 2 "ft" }}
{PARA 0 "" 0 "" {TEXT -1 17 "The real part of " }{TEXT 259 2 "fr" }
{TEXT -1 46 " is the numerator of the partial derivative   " }
{XPPEDIT 18 0 "diff(abs(FF)(c,x,a),r);" "6#-%%diffG6$--%$absG6#%#FFG6%
%\"cG%\"xG%\"aG%\"rG" }{TEXT -1 2 "  " }}{PARA 0 "" 0 "" {TEXT -1 17 "
The real part of " }{TEXT 260 2 "ft" }{TEXT -1 46 " is the numerator o
f the partial derivative   " }{XPPEDIT 18 0 "diff(abs(FF)(c,x,a),theta
