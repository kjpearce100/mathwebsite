{SECT 0 {EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT 
-1 92 "file:  campbell-maple-substep3.mws -- verify that H(c,x,a) has \+
no local extreme point on O_x" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 8 "restart;" }}}{EXCHG {PARA 0 "
" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 7 "Define " }{XPPEDIT 
258 0 "m = m(alpha);" "6#/%\"mG-F$6#%&alphaG" }{TEXT -1 84 "  which is
 the bound on the radius of majorization specified in Campbell's Theor
em 2" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 37 "m := alpha+1 - sqrt(alpha^2+2*alpha);" }}{PARA 11 "" 
1 "" {XPPMATH 20 "6#>%\"mG,(%&alphaG\"\"\"F'F'*$,&*$)F&\"\"#F'F'*&F,F'
F&F'F'#F'F,!\"\"" }}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "
" 0 "" {TEXT -1 16 "Define the left " }{XPPEDIT 18 0 "l[1] = l[1](alph
a);" "6#/&%\"lG6#\"\"\"-&F%6#F'6#%&alphaG" }{TEXT -1 11 " and right " 
}{XPPEDIT 18 0 "l[2] = l[2](alpha);" "6#/&%\"lG6#\"\"#-&F%6#F'6#%&alph
aG" }{TEXT -1 33 " sides of the critical trapezoid " }{TEXT 256 1 "T" 
}{TEXT -1 1 " " }}{PARA 0 "" 0 "" {TEXT -1 5 "     " }}}{EXCHG {PARA 
0 "> " 0 "" {MPLTEXT 1 0 41 "l1 := (alpha-1)/5;\nl2 := (2-alpha)/(5/2)
;" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#l1G,&*&\"\"&!\"\"%&alphaG\"\"
\"F*#F*F'F(" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#l2G,&#\"\"%\"\"&\"\"
\"*(\"\"#F)F(!\"\"%&alphaGF)F," }}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "
" }}{PARA 0 "" 0 "" {TEXT -1 30 "We define below the functions " }
{TEXT 257 17 "F, E, D, C, B, H " }{TEXT -1 15 " (functions of " }
{TEXT 259 7 "c, x, a" }{TEXT -1 81 " ) which arise in the formulation \+
of the basic inequality in line (4) and page 4." }}{PARA 0 "" 0 "" 
{TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 102 "Note, for convenience in
 this worksheet each such function is represented as a (capital) DOUBL
E letter" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 
101 "Note further, for each such XX the function XXc will be construct
ed to be the complex conjugate of XX" }}{PARA 0 "" 0 "" {TEXT -1 0 "" 
}}{PARA 0 "" 0 "" {TEXT -1 46 "Finally, aXX is the product (XX)(XXc) =
 |XX|^2" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 302 "FF := a + 2*c + a*c^2;\nFFc := a + 2*cc + a*cc^2;\na
FF := simplify(4*x^2*sin(theta)^2+4*x^3*cos(theta)*a*sin(theta)^2+2*x^
4*a^2*cos(theta)^2*sin(theta)^2+4*a*x*cos(theta)+2*a^2*x^2*cos(theta)^
2+a^2-2*a^2*x^2*sin(theta)^2+4*x^2*cos(theta)^2+4*x^3*cos(theta)^3*a+x
^4*a^2*cos(theta)^4+x^4*a^2*sin(theta)^4);" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#>%#FFG,(%\"aG\"\"\"*&\"\"#F'%\"cGF'F'*&F&F')F*F)F'F'" }
}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%$FFcG,(%\"aG\"\"\"*&\"\"#F'%#ccGF'F
'*&F&F')F*F)F'F'" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%$aFFG,0**\"\"%\"
\"\")%\"aG\"\"#F()%\"xGF+F()-%$cosG6#%&thetaGF+F(F(**F'F(F*F(F-F(F/F(F
(*$F)F(F(*(F+F(F)F(F,F(!\"\"*&F'F(F,F(F(**F'F()F-\"\"$F(F/F(F*F(F(*&)F
-F'F(F)F(F(" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 93 "EE := 1-c;\n
EEc := 1-cc;\naEE := simplify(1-2*x*cos(theta)+x^2*cos(theta)^2+x^2*si
n(theta)^2);\n" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#EEG,&\"\"\"F&%\"c
G!\"\"" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%$EEcG,&\"\"\"F&%#ccG!\"\"
" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%$aEEG,(\"\"\"F&*(\"\"#F&%\"xGF&-
%$cosG6#%&thetaGF&!\"\"*$)F)F(F&F&" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 285 "DD := 1 + a*c - x^2*(a+c);\nDDc := 1 + a*cc - x^2*(a
+cc);\naDD := simplify(1+x^6*sin(theta)^2+2*a*x*cos(theta)+a^2*x^2*cos
(theta)^2-2*x^2*a-2*x^3*cos(theta)+x^4*a^2+x^6*cos(theta)^2-2*a^2*x^3*
cos(theta)-2*a*x^4*cos(theta)^2-2*a*x^4*sin(theta)^2+2*x^5*cos(theta)*
a+a^2*x^2*sin(theta)^2);\n" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#DDG,(
\"\"\"F&*&%\"aGF&%\"cGF&F&*&)%\"xG\"\"#F&,&F(F&F)F&F&!\"\"" }}{PARA 
11 "" 1 "" {XPPMATH 20 "6#>%$DDcG,(\"\"\"F&*&%\"aGF&%#ccGF&F&*&)%\"xG
\"\"#F&,&F(F&F)F&F&!\"\"" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%$aDDG,6
\"\"\"F&*(\"\"#F&)%\"xG\"\"$F&-%$cosG6#%&thetaGF&!\"\"**F(F&)F*\"\"&F&
F,F&%\"aGF&F&**F(F&F4F&F*F&F,F&F&**F(F&)F4F(F&F)F&F,F&F0*&)F*\"\"%F&F7
F&F&*(F(F&)F*F(F&F4F&F0*$)F*\"\"'F&F&*(F(F&F4F&F9F&F0*&F7F&F<F&F&" }}}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 55 "CC := abs(FF)*(1-x^2)^2;\nBB
 := abs(DD)-x*(1-a)*abs(EE);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#CCG
*&-%$absG6#,(%\"aG\"\"\"*&\"\"#F+%\"cGF+F+*&F*F+)F.F-F+F+F+),&F+F+*$)%
\"xGF-F+!\"\"F-F+" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#BBG,&-%$absG6#
,(\"\"\"!\"\"*&%\"aGF*%\"cGF*F+*&)%\"xG\"\"#F*,&F-F*F.F*F*F*F**(F1F*,&
F*F*F-F+F*-F'6#,&F.F*F*F+F*F+" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 
0 15 "HH := CC/BB^2;\n" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#HHG*(-%$a
bsG6#,(%\"aG\"\"\"*&\"\"#F+%\"cGF+F+*&F*F+)F.F-F+F+F+,&F+F+*$)%\"xGF-F
+!\"\"F-,&-F'6#,(F+F5*&F*F+F.F+F5*&F3F+,&F*F+F.F+F+F+F+*(F4F+,&F+F+F*F
5F+-F'6#,&F.F+F+F5F+F5!\"#" }}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}
{PARA 0 "" 0 "" {TEXT -1 40 "We introduce here the complex parameter \+
" }{XPPEDIT 18 0 "c = xe^(i*theta);" "6#/%\"cG)%#xeG*&%\"iG\"\"\"%&the
taGF)" }{TEXT -1 28 "  and its complex conjugate " }{XPPEDIT 18 0 "cc \+
= xe^(-i*theta);" "6#/%#ccG)%#xeG,$*&%\"iG\"\"\"%&thetaGF*!\"\"" }
{TEXT -1 2 "  " }}{PARA 0 "" 0 "" {TEXT -1 3 "   " }}}{EXCHG {PARA 0 "
> " 0 "" {MPLTEXT 1 0 72 "c := x*(cos(theta) + I*sin(theta));\ncc := x
*(cos(theta) - I*sin(theta));" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%\"c
G*&%\"xG\"\"\",&-%$cosG6#%&thetaGF'*&-%$sinGF+F'^#F'F'F'F'" }}{PARA 
11 "" 1 "" {XPPMATH 20 "6#>%#ccG*&%\"xG\"\"\",&-%$cosG6#%&thetaGF'*&^#
!\"\"F'-%$sinGF+F'F'F'" }}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}
{PARA 0 "" 0 "" {TEXT -1 23 "We introduce functions " }{TEXT 262 2 "fx
" }{TEXT -1 5 " and " }{TEXT 263 2 "ft" }}{PARA 0 "" 0 "" {TEXT -1 17 
"The real part of " }{TEXT 260 2 "fx" }{TEXT -1 46 " is the numerator \+
of the partial derivative   " }{XPPEDIT 18 0 "diff(abs(FF)(c,x,a),x);
" "6#-%%diffG6$--%$absG6#%#FFG6%%\"cG%\"xG%\"aGF-" }{TEXT -1 2 "  " }}
{PARA 0 "" 0 "" {TEXT -1 17 "The real part of " }{TEXT 261 2 "ft" }
{TEXT -1 46 " is the numerator of the partial derivative   " }
{XPPEDIT 18 0 "diff(abs(FF)(c,x,a),theta);" "6#-%%diffG6$--%$absG6#%#F
FG6%%\"cG%\"xG%\"aG%&thetaG" }{TEXT -1 3 "   " }}{PARA 0 "" 0 "" 
{TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 47 "The denomimator of each p
artial derivative is  " }{XPPEDIT 18 0 "abs(FF);" "6#-%$absG6#%#FFG" }
}{PARA 0 "" 0 "" {TEXT -1 1 " " }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 
1 0 70 "fx := expand(FFc*(2*c+2*a*c^2)/x);\nft := expand(FFc*I*(2*c+2*
a*c^2));\n" }}{PARA 12 "" 1 "" {XPPMATH 20 "6#>%#fxG,>*(\"\"%\"\"\"%\"
xGF()-%$sinG6#%&thetaG\"\"#F(F(*(F'F(F)F()-%$cosGF-F/F(F(**F/F()F)\"\"
$F()%\"aGF/F()F2F'F(F(**F/F(F5F(F7F()F+F'F(F(*(F/F(F8F(F2F(F(**F/F(F)F
(F7F(F1F(F(**F/F(F)F(F7F(F*F(!\"\"**\"\"'F()F)F/F()F2F6F(F8F(F(*,FAF(F
BF(F2F(F8F(F*F(F(*,F'F(F5F(F7F(F1F(F*F(F(**^#F/F(FBF(F8F()F+F6F(F(*(FG
F(F8F(F+F(F(*,^#F'F(F)F(F7F(F2F(F+F(F(*,FGF(FBF(F8F(F1F(F+F(F(" }}
{PARA 12 "" 1 "" {XPPMATH 20 "6#>%#ftG,>*(^#\"\"%\"\"\")%\"xG\"\"#F))-
%$sinG6#%&thetaGF,F)F)*(F'F)F*F))-%$cosGF0F,F)F)**^#F,F))F+F(F))%\"aGF
,F))F4F(F)F)**F7F)F8F)F9F))F.F(F)F)**F7F)F:F)F+F)F4F)F)**F7F)F9F)F*F)F
3F)F)**^#!\"#F)F9F)F*F)F-F)F)**^#\"\"'F))F+\"\"$F))F4FGF)F:F)F)*,FDF)F
FF)F4F)F:F)F-F)F)*,F'F)F8F)F9F)F3F)F-F)F)**F,F)FFF))F.FGF)F:F)!\"\"**F
,F)F:F)F+F)F.F)FM*,F(F)F*F)F9F)F4F)F.F)FM*,F,F)FFF)F3F)F:F)F.F)FM" }}}
{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 37 "We
 temporarily substitute a variable " }{TEXT 267 1 "y" }{TEXT -1 5 " fo
r " }{TEXT 264 1 "i" }{TEXT -1 43 "  so that we can pick off the real \+
part of " }{TEXT 265 2 "fx" }{TEXT -1 8 " and of " }{TEXT 266 2 "ft" }
}{PARA 0 "" 0 "" {TEXT -1 0 "" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 
0 41 "fxs := subs(I=y,fx);\nfts := subs(I=y,ft);" }}{PARA 12 "" 1 "" 
{XPPMATH 20 "6#>%$fxsG,>*(\"\"%\"\"\"%\"xGF()-%$sinG6#%&thetaG\"\"#F(F
(*(F'F(F)F()-%$cosGF-F/F(F(**F/F()F)\"\"$F()%\"aGF/F()F2F'F(F(**F/F(F5
F(F7F()F+F'F(F(*(F/F(F8F(F2F(F(**F/F(F)F(F7F(F1F(F(**F/F(F)F(F7F(F*F(!
\"\"**\"\"'F()F)F/F()F2F6F(F8F(F(*,FAF(FBF(F2F(F8F(F*F(F(*,F'F(F5F(F7F
(F1F(F*F(F(*,F/F(%\"yGF(FBF(F8F()F+F6F(F(**F/F(FGF(F8F(F+F(F(*.F'F(FGF
(F)F(F7F(F2F(F+F(F(*.F/F(FGF(FBF(F8F(F1F(F+F(F(" }}{PARA 12 "" 1 "" 
{XPPMATH 20 "6#>%$ftsG,>**\"\"%\"\"\"%\"yGF()%\"xG\"\"#F()-%$sinG6#%&t
hetaGF,F(F(**F'F(F)F(F*F()-%$cosGF0F,F(F(*,F,F(F)F()F+F'F()%\"aGF,F()F
4F'F(F(*,F,F(F)F(F7F(F8F()F.F'F(F(*,F,F(F)F(F9F(F+F(F4F(F(*,F,F(F)F(F8
