{SECT 0 {EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT 
-1 68 "file:  campbell-maple-substep2b.mws --  verify substep2 on set \+
E(r)-" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 8 "restart;" }}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}
{PARA 0 "" 0 "" {TEXT -1 7 "Define " }{XPPEDIT 258 0 "m = m(alpha);" "
6#/%\"mG-F$6#%&alphaG" }{TEXT -1 84 "  which is the bound on the radiu
s of majorization specified in Campbell's Theorem 2" }}{PARA 0 "" 0 "
" {TEXT -1 0 "" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 37 "m := alph
a+1 - sqrt(alpha^2+2*alpha);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%\"mG
,(%&alphaG\"\"\"F'F'*$,&*$)F&\"\"#F'F'*&F,F'F&F'F'#F'F,!\"\"" }}}
{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 16 "De
fine the left " }{XPPEDIT 18 0 "l[1] = l[1](alpha);" "6#/&%\"lG6#\"\"
\"-&F%6#F'6#%&alphaG" }{TEXT -1 11 " and right " }{XPPEDIT 18 0 "l[2] \+
= l[2](alpha);" "6#/&%\"lG6#\"\"#-&F%6#F'6#%&alphaG" }{TEXT -1 33 " si
des of the critical trapezoid " }{TEXT 256 1 "T" }{TEXT -1 1 " " }}
{PARA 0 "" 0 "" {TEXT -1 5 "     " }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 41 "l1 := (alpha-1)/5;\nl2 := (2-alpha)/(5/2);" }}{PARA 
11 "" 1 "" {XPPMATH 20 "6#>%#l1G,&*&\"\"&!\"\"%&alphaG\"\"\"F*#F*F'F(
" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#l2G,&#\"\"%\"\"&\"\"\"*(\"\"#F)
F(!\"\"%&alphaGF)F," }}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 
0 "" 0 "" {TEXT -1 30 "We define below the functions " }{TEXT 257 17 "
F, E, D, C, B, H " }{TEXT -1 16 " (functions of  " }{TEXT 259 7 "c, x,
 a" }{TEXT -1 69 " ) which arise in the formulation of the basic inequ
ality in line (4)" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" 
{TEXT -1 102 "Note, for convenience in this worksheet each such functi
on is represented as a (capital) DOUBLE letter" }}{PARA 0 "" 0 "" 
{TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 33 "The set E(r)-  is defined
 as the " }{XPPEDIT 18 0 "theta" "6#%&thetaG" }{TEXT -1 28 "=pi bounda
ry of the region \{" }{XPPEDIT 18 0 "c = re^(i*theta)" "6#/%\"cG)%#reG
*&%\"iG\"\"\"%&thetaGF)" }{TEXT -1 19 " :  0 < r < x, 0 < " }{XPPEDIT 
18 0 "theta" "6#%&thetaG" }{TEXT -1 8 " < pi\}, " }}{PARA 0 "" 0 "" 
{TEXT -1 31 "i.e., on this boundary we have " }{TEXT 260 1 "c" }{TEXT 
-1 4 " = -" }{TEXT 261 1 "r" }{TEXT -1 26 "  in all of the functions \+
" }{TEXT 262 17 "F, E, D, C, B, H " }{TEXT -1 14 " defined below" }}
{PARA 0 "" 0 "" {TEXT -1 0 "" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 
0 48 "FF := a - 2*r + a*r^2;\nfff := (x^2-r^2)*(1-a^2);" }}{PARA 11 "
" 1 "" {XPPMATH 20 "6#>%#FFG,(%\"aG\"\"\"*&\"\"#F'%\"rGF'!\"\"*&F&F')F
*F)F'F'" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%$fffG*&,&*$)%\"xG\"\"#\"
\"\"F+*$)%\"rGF*F+!\"\"F+,&F+F+*$)%\"aGF*F+F/F+" }}}{EXCHG {PARA 0 "> \+
" 0 "" {MPLTEXT 1 0 10 "EE := 1+r;" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#
>%#EEG,&\"\"\"F&%\"rGF&" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 26 "
DD := 1 - a*r - x^2*(a-r);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#DDG,(
\"\"\"F&*&%\"aGF&%\"rGF&!\"\"*&)%\"xG\"\"#F&,&F(F&F)F*F&F*" }}}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 48 "CC := abs(FF)*(1-x^2)+fff;\nBB := D
D-x*(1-a)*EE;\n" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#CCG,&*&-%$absG6#
,(%\"aG\"\"\"*&\"\"#F,%\"rGF,!\"\"*&F+F,)F/F.F,F,F,,&F,F,*$)%\"xGF.F,F
0F,F,*&,&F4F,*$F2F,F0F,,&F,F,*$)F+F.F,F0F,F," }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#>%#BBG,*\"\"\"F&*&%\"aGF&%\"rGF&!\"\"*&)%\"xG\"\"#F&,&F
(F&F)F*F&F**(F-F&,&F&F&F(F*F&,&F&F&F)F&F&F*" }}}{EXCHG {PARA 0 "" 0 "
" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 55 "Note, technically, HH s
hould be multiplied by a factor " }{XPPEDIT 18 0 "1-x^2;" "6#,&\"\"\"F
$*$%\"xG\"\"#!\"\"" }{TEXT -1 12 ", but since " }{TEXT 263 1 "x" }
{TEXT -1 112 " is fixed for the arguments in this substep of Step 3, t
his factor has been dropped in this particular worksheet" }}{PARA 0 "
" 0 "" {TEXT -1 4 "    " }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 15 "
HH := CC/BB^2;\n" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#HHG*&,&*&-%$abs
G6#,(%\"aG\"\"\"*&\"\"#F-%\"rGF-!\"\"*&F,F-)F0F/F-F-F-,&F-F-*$)%\"xGF/
F-F1F-F-*&,&F5F-*$F3F-F1F-,&F-F-*$)F,F/F-F1F-F-F-,*F-F-*&F,F-F0F-F1*&F
6F-,&F,F-F0F1F-F1*(F7F-,&F-F-F,F1F-,&F-F-F0F-F-F1!\"#" }}}{EXCHG 
{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 39 "Graphical
 view for specific values of  " }{XPPEDIT 18 0 "alpha;" "6#%&alphaG" }
{TEXT -1 3 " , " }{TEXT 264 1 "x" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}
{PARA 0 "" 0 "" {TEXT -1 35 "Note the output has been suppressed" }}
{PARA 0 "" 0 "" {TEXT -1 2 "  " }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 
1 0 88 "alpha := 1.5: x := m:\nplot3d(HH,r=0..x,a=l1..l2,axes=boxed):
\nalpha := 'alpha': x := 'x':" }}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "
" }}{PARA 0 "" 0 "" {TEXT -1 101 "We will divide the domain \{(r,a)\} \+
into two subsets on which the sign of  FF= a -2r + ar^2 is constant" }
}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 96 "Let S1 =
 \{(r,a) |  0 < r <  (1-sqrt(1-a^2))/a, l1 < a < l2\}\nHere | a -2r + \+
ar^2| = a - 2r + ar^2" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 
"" {TEXT -1 99 "Let S2 = \{(r,a) |  (1-sqrt(1-a^2))/a < r < x, l1 < a \+
< l2\}\nHere  | a -2r + ar^2| = -(a - 2r + ar^2)" }}{PARA 0 "" 0 "" 
{TEXT -1 0 "" }}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "
" {TEXT -1 22 "On S1 we have HH = HH1" }}{PARA 13 "" 1 "" {TEXT -1 0 "
" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 36 "HH1 := ((FF)*(1-x^2) + \+
fff) / BB^2 ;" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%$HH1G*&,&*&,(%\"aG
\"\"\"*&\"\"#F*%\"rGF*!\"\"*&F)F*)F-F,F*F*F*,&F*F**$)%\"xGF,F*F.F*F**&
,&F2F**$F0F*F.F*,&F*F**$)F)F,F*F.F*F*F*,*F*F**&F)F*F-F*F.*&F3F*,&F)F*F
-F.F*F.*(F4F*,&F*F*F)F.F*,&F*F*F-F*F*F.!\"#" }}}{EXCHG {PARA 0 "" 0 "
" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 39 "Graphical view for spec
ific values of  " }{XPPEDIT 18 0 "alpha;" "6#%&alphaG" }{TEXT -1 3 " ,
 " }{TEXT 265 1 "x" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" 
{TEXT -1 35 "Note the output has been suppressed" }}{PARA 0 "" 0 "" 
{TEXT -1 2 "  " }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 106 "alpha :=
 1.2: x := m:\nplot3d(HH1,r=0..(1-sqrt(1-a^2))/a,a=l1..l2,axes=boxed):
\nalpha := 'alpha': x := 'x':\n" }}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 
"" }}{PARA 0 "" 0 "" {TEXT -1 64 "The function HH1 is defined on on S1
 relative to computing HH.  " }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 
0 "" 0 "" {TEXT -1 116 "We consdier the extended function (for which w
e will use the same name HH1) defined by relaxing the restriction on r
" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 78 "We wi
ll show that the extended function is increasing in a and decreasing i
n r" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 89 "alpha := 1.2: x := m:\nplot3d(HH1,r=0..x,a=l1..l2,axe
s=boxed):\nalpha := 'alpha': x := 'x':" }}}{EXCHG {PARA 0 "" 0 "" 
{TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 72 "First, we will construct \+
the partial derivatives of HH1 with respect to " }{TEXT 266 1 "a" }
{TEXT -1 22 "  and with respect to " }{TEXT 267 1 "r" }}{PARA 0 "" 0 "
" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 60 "We will show that parti
al derivative of HH1 with respect to " }{TEXT 268 1 "a" }{TEXT -1 69 "
 is positive which will imply that HH1 is increasing with respect to \+
" }{TEXT 269 2 "a." }}{PARA 0 "" 0 "" {TEXT -1 60 "We will show that p
artial derivative of HH1 with respect to " }{TEXT 271 1 "r" }{TEXT -1 
69 " is negative which will imply that HH1 is decreasing with respect \+
to " }{TEXT 270 2 "r." }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 
"" {TEXT -1 0 "" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 57 "HH1a := \+
normal(diff(HH1,a));\nHH1r := normal(diff(HH1,r));" }}{PARA 12 "" 1 "
" {XPPMATH 20 "6#>%%HH1aG,$*(,R*&\"\"#\"\"\")%\"xG\"\"$F*!\"\"*(F-F*F+
F*%\"rGF*F.**F)F*F+F*%\"aGF*F0F*F**&)F0F-F*F+F*F**()F0F)F*F+F*F2F*F**&
F+F*F2F*F**()F,F)F*F2F*F0F*F.*(F4F*F9F*F2F*F.*(F)F*F9F*F0F*F**(F)F*F2F
*F9F*F.*$F9F*F.*(F-F*F6F*F9F*F***F)F*F4F*F,F*F2F*F.*&F4F*F,F*F.*(F6F*F
,F*F2F*F.*&F,F*F2F*F.*(F-F*F,F*F0F*F**(F)F*F6F*F,F*F**&F2F*F0F*F*F*F**
(F)F*F2F*F6F*F**&F4F*F2F*F**&F-F*F6F*F.*&F)F*F4F*F.F*,*FBF.*&F,F*F0F*F
*FEF*F*F.F.,2F*F*FEF.*&F2F*F9F*F.*&F9F*F0F*F*F,F.FKF.FBF**(F,F*F2F*F0F
*F*!\"#F." }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%%HH1rG,$**\"\"#\"\"\",B
*$)%\"xG\"\"$F(!\"\"*&F+F(%\"rGF(F.*()%\"aGF'F(F+F(F0F(F(*&F2F(F+F(F(*
&F3F()F,F'F(F.*&F6F()F3F-F(F(*&F6F(F2F(F(*$F6F(F.*&F,F(F0F(F(*(F2F(F0F
(F,F(F.*(F0F(F8F(F,F(F.*(F,F(F3F(F0F(F(F(F(F0F(*&F0F(F2F(F.*$F2F(F.F(,
**&F,F(F3F(F.F;F(*&F3F(F0F(F(F(F.F.,2F(F(FCF.F5F.*&F6F(F0F(F(F,F.F;F.F
BF(F>F(!\"#F(" }}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 
"" {TEXT -1 139 "Since the denominators of the above partial derivativ
es are negative, we will pick off the negative of the numerators to de
termine the sign" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}}{EXCHG {PARA 0 ">
 " 0 "" {MPLTEXT 1 0 41 "nha := -numer(HH1a);\nnhr := -numer(HH1r);" }
}{PARA 12 "" 1 "" {XPPMATH 20 "6#>%$nhaG,R*&\"\"#\"\"\")%\"xG\"\"$F(!
\"\"*(F+F(F)F(%\"rGF(F,**F'F(F)F(%\"aGF(F.F(F(*&)F.F+F(F)F(F(*()F.F'F(
F)F(F0F(F(*&F)F(F0F(F(*()F*F'F(F0F(F.F(F,*(F2F(F7F(F0F(F,*(F'F(F7F(F.F
(F(*(F'F(F0F(F7F(F,*$F7F(F,*(F+F(F4F(F7F(F(**F'F(F2F(F*F(F0F(F,*&F2F(F
*F(F,*(F4F(F*F(F0F(F,*&F*F(F0F(F,*(F+F(F*F(F.F(F(*(F'F(F4F(F*F(F(*&F0F
(F.F(F(F(F(*(F'F(F0F(F4F(F(*&F2F(F0F(F(*&F+F(F4F(F,*&F'F(F2F(F," }}
{PARA 11 "" 1 "" {XPPMATH 20 "6#>%$nhrG,B*&\"\"#\"\"\")%\"xG\"\"$F(F(*
(F'F(F)F(%\"rGF(F(**F'F()%\"aGF'F(F)F(F-F(!\"\"*(F'F(F/F(F)F(F1*(F'F(F
0F()F*F'F(F(*(F'F(F4F()F0F+F(F1*(F'F(F4F(F/F(F1*&F'F(F4F(F(*(F'F(F*F(F
-F(F1**F'F(F/F(F-F(F*F(F(**F'F(F-F(F6F(F*F(F(**F'F(F*F(F0F(F-F(F1F'F1*
&F'F(F-F(F1*(F'F(F-F(F/F(F(*&F'F(F/F(F(" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 25 "factor(nha);\nfactor(nhr);" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#*&,&\"\"\"F%%\"rGF%F%,J**\"\"#F%)F&F)F%%\"xGF%%\"aGF%!
\"\"*&F*F%)F+\"\"$F%F%*(F,F%F*F%)F+F)F%F-*&F)F%F*F%F-*&F*F%F+F%F-*&F,F
%F*F%F%*(F/F%F,F%F&F%F%F&F-*(F0F%F2F%F&F%F%*(F+F%F,F%F&F%F%*(F0F%F+F%F
&F%F%*&F,F%F&F%F%*&F/F%F&F%F-*(F2F%F,F%F&F%F%*&F/F%F,F%F%*(F)F%F,F%F2F
%F-F%F%*&F)F%F/F%F-*$F2F%F-*&F+F%F,F%F-F%" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#,$**\"\"#\"\"\",&F&!\"\"%\"aGF&F&,&F)F&F&F&F&,2*&F)F&)%
\"xGF%F&F&*(F.F&F)F&%\"rGF&F(*&)F.\"\"$F&F0F&F&*$F2F&F&*$F-F&F&*&F.F&F
0F&F(F0F(F&F(F&F(" }}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "
" 0 "" {TEXT -1 9 "The term " }{TEXT 272 4 "nhaf" }{TEXT -1 18 " is ob
tained from " }{TEXT 273 3 "nha" }{TEXT -1 48 " by removing the leadin
