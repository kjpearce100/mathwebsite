&F&F&F&,2*(%\"xGF&F)F&%\"rGF&F&*&F)F&)F-F%F&F(*&F-F&F.F&F(F.F&*$F0F&F&
*$)F-\"\"$F&F(*&F4F&F.F&F&F&F(F&F&" }}}{EXCHG {PARA 0 "" 0 "" {TEXT 
-1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 9 "The term " }{TEXT 301 4 "nhaf" }
{TEXT -1 18 " is obtained from " }{TEXT 302 3 "nha" }{TEXT -1 26 " by \+
removing the leading (" }{TEXT 308 8 "negative" }{TEXT -1 14 ") factor
 from " }{TEXT 304 3 "nha" }{TEXT -1 1 " " }}{PARA 0 "" 0 "" {TEXT -1 
0 "" }}{PARA 0 "" 0 "" {TEXT -1 4 "and " }}{PARA 0 "" 0 "" {TEXT -1 0 
"" }}{PARA 0 "" 0 "" {TEXT -1 9 "the term " }{TEXT 306 4 "nhrf" }
{TEXT -1 18 " is obtained from " }{TEXT 307 3 "nhr" }{TEXT -1 48 " by \+
removingthe leading (positive) factors from " }{TEXT 303 3 "nhr" }}
{PARA 0 "" 0 "" {TEXT -1 0 "" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 
0 62 "nhaf := normal(nha/(-1+r));\nnhrf := normal(nhr/( 2*(1-a^2) ));
" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%%nhafG,J*(%\"aG\"\"\")%\"rG\"\"#
F()%\"xGF+F(F(*&F)F(F-F(F(*&F+F(F)F(!\"\"**F+F(F)F(F-F(F'F(F0*&F)F()F-
