1 "" {XPPMATH 20 "6#>%%nhrfG,2*(%\"xG\"\"\"%\"aGF(%\"rGF(!\"\"*&F)F()F
'\"\"#F(F(*&F'F(F*F(F(F*F+*$F-F(F+*$)F'\"\"$F(F(*&F2F(F*F(F+F(F(" }}}
{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 23 "We
 will show that both " }{TEXT 305 10 "nhaf, nhrf" }{TEXT -1 5 "  > 0" 
}}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 32 "Then, H
H2 will be decreasing in " }{TEXT 309 1 "a" }{TEXT -1 19 " and increas
ing in " }{TEXT 310 1 "r" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 33 "collect(nhaf,a);\ncollect(nhrf,a);
" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#,8*&,6*(\"\"#\"\"\")%\"rGF'F(%\"xG
F(!\"\"*&F)F()F+F'F(F(*$F)F(F,*&)F+\"\"$F(F*F(F,*&F+F(F*F(F,F*F(*&F.F(
F*F(F(*$F1F(F(*&F'F(F.F(F(F+F,F(%\"aGF(F(*&F'F(F)F(F,*&F)F(F1F(F,*&F)F
(F+F(F(*(F2F(F+F(F*F(F(*(F2F(F.F(F*F(F,F*F(F0F,*&F'F(F1F(F(*$F.F(F,F(F
(" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#,0*&,&*$)%\"xG\"\"#\"\"\"F**&F(F*
%\"rGF*!\"\"F*%\"aGF*F*F,F-*&)F(\"\"$F*F,F*F-F*F**$F0F*F*F&F-F+F*" }}}
{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 9 "Cle
arly, " }{TEXT 311 4 "nhaf" }{TEXT -1 5 " and " }{TEXT 312 4 "nhar" }
{TEXT -1 16 " are linear in a" }}{PARA 0 "" 0 "" {TEXT -1 48 "Hence, w
e can obtain lower and upper bounds for " }{TEXT 313 4 "nhaf" }{TEXT 
-1 5 " and " }{TEXT 314 4 "nhar" }{TEXT -1 14 " by replacing " }{TEXT 
315 1 "a" }{TEXT -1 47 " by its lower and upper bounds, which are 0 <=
 " }{TEXT 316 1 "a" }{TEXT -1 7 " <= 2/5" }}{PARA 0 "" 0 "" {TEXT -1 
0 "" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 99 "sa_0 := subs(a=0,nha
f);\nsa_1 := subs(a=2/5,nhaf);\nta_0 := subs(a=0,nhrf);\nta_1 := subs(
a=2/5,nhrf);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%%sa_0G,6*&)%\"rG\"\"
#\"\"\")%\"xG\"\"$F*!\"\"*&F'F*F,F*F**&F)F*F'F*F.*(F-F*)F,F)F*F(F*F.*(
F-F*F,F*F(F*F*F(F**&F+F*F(F*F.*$F2F*F.*&F)F*F+F*F*F*F*" }}{PARA 11 "" 
1 "" {XPPMATH 20 "6#>%%sa_1G,:*&)%\"rG\"\"#\"\"\")%\"xG\"\"$F*!\"\"*&#
F*\"\"&F**&F'F*F,F*F*F**&#\"#7F1F**$F'F*F*F.*&#F)F1F**&F'F*)F,F)F*F*F*
*&#\"#8F1F**&F,F*F(F*F*F**&#F=F1F**&F:F*F(F*F*F.*&#\"\"(F1F**&F+F*F(F*
F*F.*&#FDF1F*F(F*F**&#F)F1F*F,F*F.*&#F5F1F**$F+F*F*F**&#F*F1F**$F:F*F*
F.F*F*" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%%ta_0G,.%\"rG!\"\"*&)%\"xG
\"\"$\"\"\"F&F,F'F,F,*$F)F,F,*$)F*\"\"#F,F'*&F*F,F&F,F," }}{PARA 11 "
" 1 "" {XPPMATH 20 "6#>%%ta_1G,.*&#\"\"$\"\"&\"\"\"*&%\"xGF*%\"rGF*F*F
**&#F(F)F**$)F,\"\"#F*F*!\"\"*&)F,F(F*F-F*F3*$F5F*F*F-F3F*F*" }}}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 67 "collect(sa_0,r);\ncollect(sa
_1,r);\ncollect(ta_0,r);\ncollect(ta_1,r);" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#,,*&,(*$)%\"xG\"\"$\"\"\"!\"\"F(F*\"\"#F+F*)%\"rGF,F*F*
*&,**&F)F*)F(F,F*F+*&F)F*F(F*F*F*F*F&F+F*F.F*F**$F2F*F+*&F,F*F'F*F*F*F
*" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#,.*&,**$)%\"xG\"\"$\"\"\"!\"\"*&#
F*\"\"&F*F(F*F*#\"#7F.F+*&#\"\"#F.F**$)F(F3F*F*F*F*)%\"rGF3F*F**&,**&#
\"#8F.F*F(F*F**&#F<F.F*F4F*F+*&#\"\"(F.F*F&F*F+#FAF.F*F*F7F*F**(F3F*F.
F+F(F*F+*(F0F*F.F+F(F)F**&F.F+F(F3F+F*F*" }}{PARA 11 "" 1 "" {XPPMATH 
20 "6#,**&,(*$)%\"xG\"\"$\"\"\"!\"\"F*F+F(F*F*%\"rGF*F*F&F**$)F(\"\"#F
*F+F*F*" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#,**&,(*&#\"\"$\"\"&\"\"\"%
\"xGF*F**$)F+F(F*!\"\"F*F.F*%\"rGF*F**(F(F*F)F.F+\"\"#F.F,F*F*F*" }}}
{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 161 "S
ince the coefficient of r^2 in sa_0 and in sa_1 is negative, a lower b
ound for sa_0 and sa_1 can be obtained by replacing r^2 with its large
st value, namely x^2" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}}{EXCHG {PARA 
0 "> " 0 "" {MPLTEXT 1 0 57 "saa_0 := subs(r^2=x^2,sa_0);\nsaa_1 := su
bs(r^2=x^2,sa_1);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%&saa_0G,2*$)%\"
xG\"\"&\"\"\"!\"\"*&\"\"$F*)F(F-F*F**&F-F*)F(\"\"#F*F+*(F-F*F0F*%\"rGF
*F+*(F-F*F(F*F3F*F*F3F**&F.F*F3F*F+F*F*" }}{PARA 11 "" 1 "" {XPPMATH 
20 "6#>%&saa_1G,6*$)%\"xG\"\"&\"\"\"!\"\"*&#\"#8F)F**$)F(\"\"$F*F*F**&
#F.F)F**$)F(\"\"#F*F*F+*&#F6F)F**$)F(\"\"%F*F*F**&F-F**&F(F*%\"rGF*F*F
**&#F.F)F**&F5F*F>F*F*F+*&#\"\"(F)F**&F0F*F>F*F*F+*&#FDF)F*F>F*F**&#F6
F)F*F(F*F+F*F*" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 69 "collect(s
aa_0,r);\ncollect(saa_1,r);\ncollect(ta_0,r);\ncollect(ta_1,r);" }}
{PARA 11 "" 1 "" {XPPMATH 20 "6#,,*&,**&\"\"$\"\"\")%\"xG\"\"#F(!\"\"*
&F'F(F*F(F(F(F(*$)F*F'F(F,F(%\"rGF(F(*$)F*\"\"&F(F,*&F'F(F/F(F(*&F'F(F
)F(F,F(F(" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#,0*&,**&#\"#8\"\"&\"\"\"%
\"xGF*F**&#F(F)F**$)F+\"\"#F*F*!\"\"*&#\"\"(F)F**$)F+\"\"$F*F*F1#F4F)F
*F*%\"rGF*F**$)F+F)F*F1*(F(F*F)F1F+F7F**(F(F*F)F1F+F0F1*(F0F*F)F1F+\"
\"%F**(F0F*F)F1F+F*F1F*F*" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#,**&,(*$)
%\"xG\"\"$\"\"\"!\"\"F*F+F(F*F*%\"rGF*F*F&F**$)F(\"\"#F*F+F*F*" }}
{PARA 11 "" 1 "" {XPPMATH 20 "6#,**&,(*&#\"\"$\"\"&\"\"\"%\"xGF*F**$)F
+F(F*!\"\"F*F.F*%\"rGF*F**(F(F*F)F.F+\"\"#F.F,F*F*F*" }}}{EXCHG {PARA 
0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 64 "Clearly, each p
olynomial saa_0, saa_1, ta_0, ta_1 is linear in r" }}{PARA 0 "" 0 "" 
{TEXT -1 134 "Hence, we can obtain lower and upper bounds for saa_0, s
aa_1, ta_0, ta_1 by replacing r by its lower and upper bounds, which a
re 0 <= " }{TEXT 317 1 "r" }{TEXT -1 4 " <= " }{TEXT 318 1 "x" }}
{PARA 0 "" 0 "" {TEXT -1 0 "" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 
0 216 "saa_0_0 := subs(r=0,saa_0);\nsaa_0_1 := subs(r=x,saa_0);\nsaa_1
_0 := subs(r=0,saa_1);\nsaa_1_1 := subs(r=x,saa_1);\nta_0_0 := subs(r=
0,ta_0);\nta_0_1 := subs(r=x,ta_0);\nta_1_0 := subs(r=0,ta_1);\nta_1_1
 := subs(r=x,ta_1);\n" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%(saa_0_0G,*
*$)%\"xG\"\"&\"\"\"!\"\"*&\"\"$F*)F(F-F*F**&F-F*)F(\"\"#F*F+F*F*" }}
{PARA 11 "" 1 "" {XPPMATH 20 "6#>%(saa_0_1G,**$)%\"xG\"\"&\"\"\"!\"\"F
(F**$)F(\"\"%F*F+F*F*" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%(saa_1_0G,.
*$)%\"xG\"\"&\"\"\"!\"\"*&#\"#8F)F**$)F(\"\"$F*F*F**&#F.F)F**$)F(\"\"#
F*F*F+*&#F6F)F**$)F(\"\"%F*F*F**&#F6F)F*F(F*F+F*F*" }}{PARA 11 "" 1 "
" {XPPMATH 20 "6#>%(saa_1_1G,**$)%\"xG\"\"&\"\"\"!\"\"F(F**$)F(\"\"%F*
F+F*F*" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%'ta_0_0G,(*$)%\"xG\"\"$\"
\"\"F**$)F(\"\"#F*!\"\"F*F*" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%'ta_0
_1G,*%\"xG!\"\"*$)F&\"\"%\"\"\"F'F+F+*$)F&\"\"$F+F+" }}{PARA 11 "" 1 "
" {XPPMATH 20 "6#>%'ta_1_0G,(*&#\"\"$\"\"&\"\"\"*$)%\"xG\"\"#F*F*!\"\"
*$)F-F(F*F*F*F*" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%'ta_1_1G,*%\"xG!
\"\"*$)F&\"\"%\"\"\"F'F+F+*$)F&\"\"$F+F+" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 87 "tf := ta_1_1;\nplot(tf,x=0..0.3):\nss := sturmseq(tf,
x):\nsturm(ss,x,0,0.3);\nsubs(x=0,tf);" }}{PARA 11 "" 1 "" {XPPMATH 
20 "6#>%#tfG,**$)%\"xG\"\"$\"\"\"!\"\"*$)F(\"\"%F*F+F(F*F*F*" }}{PARA 
11 "" 1 "" {XPPMATH 20 "6#\"\"!" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#\"
\"\"" }}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT 
-1 236 "By the above (Sturm sequence arguments) each of the eight term
s has no zeros.  Therefore, each of the eight terms has constant sign.
\n\nSince the value at x = 0 of each of the eight terms is positive, e
ach of the eight terms is positive.\n" }}{PARA 0 "" 0 "" {TEXT -1 54 "
Hence,  the partial derivative of HH2 with respect to " }{TEXT 319 1 "
a" }{TEXT -1 14 "  is negative " }{TEXT 320 0 "" }}{PARA 0 "" 0 "" 
{TEXT -1 68 "Hence,  the partial derivative of HH2 with respect to r  \+
is positive" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}}{EXCHG {PARA 0 "" 0 "
" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 49 "Hence, HH2 is decreasin
g in a and increasing in r" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 
"" 0 "" {TEXT -1 40 "Hence, HH2 maximizes at a = l1 and r = x" }}
{PARA 13 "" 1 "" {TEXT -1 0 "" }}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "
" }}{PARA 0 "" 0 "" {TEXT -1 37 "Recap the extended functions HH1, HH2
" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 8 "HH1;HH2;" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#*&,&*&,(%
\"aG\"\"\"*&\"\"#F(%\"rGF(!\"\"*&F'F()F+F*F(F(F(,&F(F(*$)%\"xGF*F(F,F(
F(*&,&F0F(*$F.F(F,F(,&F(F(*$)F'F*F(F,F(F(F(,*F(F(*&F'F(F+F(F,*&F1F(,&F
'F(F+F,F(F,*(F2F(,&F(F(F'F,F(,&F(F(F+F(F(F,!\"#" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#*&,&*&,(%\"aG\"\"\"*&\"\"#F(%\"rGF(!\"\"*&F'F()F+F*F(F(
F(,&F(F(*$)%\"xGF*F(F,F(F,*&,&F0F(*$F.F(F,F(,&F(F(*$)F'F*F(F,F(F(F(,*F
(F(*&F'F(F+F(F,*&F1F(,&F'F(F+F,F(F,*(F2F(,&F(F(F'F,F(,&F(F(F+F(F(F,!\"
#" }}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 
39 "Substitute maximum values into HH1, HH2" }}{PARA 0 "" 0 "" {TEXT 
-1 0 "" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 55 "HH1m := subs(r=0,
a=l2,HH1);\nHH2m := subs(r=x,a=l1,HH2);" }}{PARA 11 "" 1 "" {XPPMATH 
20 "6#>%%HH1mG*&,&*&,&#\"\"%\"\"&\"\"\"*(\"\"#F,F+!\"\"%&alphaGF,F/F,,
