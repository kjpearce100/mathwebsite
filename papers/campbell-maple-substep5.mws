+" }{TEXT 271 1 "x" }{TEXT -1 9 ") and (1-" }{TEXT 272 1 "x" }{TEXT 
-1 1 ")" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}}{EXCHG {PARA 0 "> " 0 "" 
