{PARA 0 "> " 0 "" {MPLTEXT 1 0 75 "ss := sturmseq(f2xa3,alpha):\nsturm
(ss,alpha,1,1.65);\nsubs(alpha=6/5,f2xa3);" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#\"\"!" }}{PARA 11 "" 1 "" {XPPMATH 20 "6##\"]qdm3xWRQN6
.R#fS-#3ZOo=fXXeX[<@(QnpMsXHdXgdR$*QzHW$)>C\"\"bq+++++++++++++++++++++
+++++++++++++++vVBS7_S9:$R;v186" }}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 
"" }}{PARA 0 "" 0 "" {TEXT -1 40 "By the above (Sturm sequence argumen
t)  " }{TEXT 311 1 "f" }{TEXT -1 1 "2" }{TEXT 312 2 "xa" }{TEXT -1 28 
"3  has no zeros; therefore, " }{TEXT 313 1 "f" }{TEXT -1 1 "2" }
{TEXT 314 2 "xa" }{TEXT -1 20 "3 has constant sign." }}{PARA 0 "" 0 "
" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 20 "Since the value at  " }
{XPPEDIT 18 0 "alpha" "6#%&alphaG" }{TEXT -1 11 " = 6/5 of  " }{TEXT 
