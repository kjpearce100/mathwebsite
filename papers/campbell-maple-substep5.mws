{PARA 0 "" 0 "" {TEXT -1 45 "We will use (repeatedly) the fact that x \+
= m(" }{XPPEDIT 18 0 "alpha" "6#%&alphaG" }{TEXT -1 30 ")  satsifies t
he relationship " }{XPPEDIT 18 0 "x^2+1 = 2*(alpha+1)*x;" "6#/,&*$%\"x
G\"\"#\"\"\"F(F(*(F'F(,&%&alphaGF(F(F(F(F&F(" }{TEXT -1 27 "  to reduc
e the powers of  " }{TEXT 267 1 "x" }{TEXT -1 4 " in " }{TEXT 268 1 "w
" }{TEXT -1 15 " from 16 to 1  " }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}
{PARA 0 "" 0 "" {TEXT -1 25 "First we will normalize  " }{TEXT 270 1 "
