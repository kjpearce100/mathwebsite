{SECT 0 {EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT 
-1 111 "file:  campbell-maple-substep5.mws -- verify that h_3 is an up
per bound for H(c,x,a) on the x=m boundary of O_x" }}{PARA 0 "" 0 "" 
{TEXT -1 0 "" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 8 "restart;" }}
}{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 7 "De
fine " }{XPPEDIT 258 0 "m = m(alpha);" "6#/%\"mG-F$6#%&alphaG" }{TEXT 
-1 84 "  which is the bound on the radius of majorization specified in
 Campbell's Theorem 2" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 37 "m := alpha+1 - sqrt(alpha^2+2*alpha
);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%\"mG,(%&alphaG\"\"\"F'F'*$,&*$
)F&\"\"#F'F'*&F,F'F&F'F'#F'F,!\"\"" }}}{EXCHG {PARA 0 "" 0 "" {TEXT 
-1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 16 "Define the left " }{XPPEDIT 18 
0 "l[1] = l[1](alpha);" "6#/&%\"lG6#\"\"\"-&F%6#F'6#%&alphaG" }{TEXT 
-1 11 " and right " }{XPPEDIT 18 0 "l[2] = l[2](alpha);" "6#/&%\"lG6#
\"\"#-&F%6#F'6#%&alphaG" }{TEXT -1 33 " sides of the critical trapezoi
d " }{TEXT 256 1 "T" }{TEXT -1 1 " " }}{PARA 0 "" 0 "" {TEXT -1 5 "   \+
  " }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 41 "l1 := (alpha-1)/5;\nl
2 := (2-alpha)/(5/2);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#l1G,&*&\"
\"&!\"\"%&alphaG\"\"\"F*#F*F'F(" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#
l2G,&#\"\"%\"\"&\"\"\"*(\"\"#F)F(!\"\"%&alphaGF)F," }}}{EXCHG {PARA 0 
"" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 30 "We define below t
he functions " }{TEXT 257 17 "F, E, D, C, B, H " }{TEXT -1 16 " (funct
ions of  " }{TEXT 259 7 "c, x, a" }{TEXT -1 81 " ) which arise in the \+
formulation of the basic inequality in line (4) and page 4." }}{PARA 
0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 102 "Note, for conv
enience in this worksheet each such function is represented as a (capi
tal) DOUBLE letter" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" 
{TEXT -1 101 "Note further, for each such XX the function XXc will be \+
constructed to be the complex conjugate of XX" }}{PARA 0 "" 0 "" 
{TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 182 "For convenience we also \+
construct functions aXX, where aXX  is the product (XX)(XXc) = |XX|^2
\n\nFinally, we also construct functions aXXs from aXX by introducing \+
the substitution cos " }{XPPEDIT 18 0 "theta;" "6#%&thetaG" }{TEXT -1 
11 "  = 2y - 1 " }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}}{EXCHG {PARA 0 "> \+
" 0 "" {MPLTEXT 1 0 349 "FF := a + 2*c + a*c^2;\nFFc := a + 2*cc + a*c
c^2;\naFF := simplify(4*x^2*sin(theta)^2+4*x^3*cos(theta)*a*sin(theta)
^2+2*x^4*a^2*cos(theta)^2*sin(theta)^2+4*a*x*cos(theta)+2*a^2*x^2*cos(
theta)^2+a^2-2*a^2*x^2*sin(theta)^2+4*x^2*cos(theta)^2+4*x^3*cos(theta
)^3*a+x^4*a^2*cos(theta)^4+x^4*a^2*sin(theta)^4);\naFFs := collect(sub
s(cos(theta)=2*y-1,aFF),y);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#FFG,
(%\"aG\"\"\"*&\"\"#F'%\"cGF'F'*&F&F')F*F)F'F'" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#>%$FFcG,(%\"aG\"\"\"*&\"\"#F'%#ccGF'F'*&F&F')F*F)F'F'" 
}}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%$aFFG,0**\"\"%\"\"\")%\"aG\"\"#F()
%\"xGF+F()-%$cosG6#%&thetaGF+F(F(**F'F(F*F(F-F(F/F(F(*$F)F(F(*(F+F(F)F
(F,F(!\"\"*&F'F(F,F(F(**F'F()F-\"\"$F(F/F(F*F(F(*&)F-F'F(F)F(F(" }}
{PARA 11 "" 1 "" {XPPMATH 20 "6#>%%aFFsG,2**\"#;\"\"\")%\"aG\"\"#F()%
\"xGF+F()%\"yGF+F(F(*&,(*(F'F(F)F(F,F(!\"\"*(\"\")F(F*F(F-F(F(*(F5F()F
-\"\"$F(F*F(F(F(F/F(F(*(F+F(F)F(F,F(F(*$F)F(F(*(\"\"%F(F*F(F-F(F3*(F<F
(F7F(F*F(F3*&)F-F<F(F)F(F(*&F<F(F,F(F(" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 139 "EE := 1-c;\nEEc := 1-cc;\naEE := simplify(1-2*x*cos(
theta)+x^2*cos(theta)^2+x^2*sin(theta)^2);\naEEs := collect(subs(cos(t
heta)=2*y-1,aEE),y);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#EEG,&\"\"\"
F&%\"cG!\"\"" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%$EEcG,&\"\"\"F&%#ccG
!\"\"" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%$aEEG,(\"\"\"F&*(\"\"#F&%\"
xGF&-%$cosG6#%&thetaGF&!\"\"*$)F)F(F&F&" }}{PARA 11 "" 1 "" {XPPMATH 
20 "6#>%%aEEsG,**(\"\"%\"\"\"%\"xGF(%\"yGF(!\"\"F(F(*&\"\"#F(F)F(F(*$)
F)F-F(F(" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 331 "DD := 1 + a*c \+
- x^2*(a+c);\nDDc := 1 + a*cc - x^2*(a+cc);\naDD := simplify(1+x^6*sin
(theta)^2+2*a*x*cos(theta)+a^2*x^2*cos(theta)^2-2*x^2*a-2*x^3*cos(thet
a)+x^4*a^2+x^6*cos(theta)^2-2*a^2*x^3*cos(theta)-2*a*x^4*cos(theta)^2-
2*a*x^4*sin(theta)^2+2*x^5*cos(theta)*a+a^2*x^2*sin(theta)^2);\naDDs :
= collect(subs(cos(theta)=2*y-1,aDD),y);" }}{PARA 11 "" 1 "" {XPPMATH 
20 "6#>%#DDG,(\"\"\"F&*&%\"aGF&%\"cGF&F&*&)%\"xG\"\"#F&,&F(F&F)F&F&!\"
\"" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%$DDcG,(\"\"\"F&*&%\"aGF&%#ccGF
&F&*&)%\"xG\"\"#F&,&F(F&F)F&F&!\"\"" }}{PARA 11 "" 1 "" {XPPMATH 20 "6
#>%$aDDG,6\"\"\"F&*(\"\"#F&)%\"xG\"\"$F&-%$cosG6#%&thetaGF&!\"\"**F(F&
)F*\"\"&F&F,F&%\"aGF&F&**F(F&F4F&F*F&F,F&F&**F(F&)F4F(F&F)F&F,F&F0*&)F
*\"\"%F&F7F&F&*(F(F&)F*F(F&F4F&F0*$)F*\"\"'F&F&*(F(F&F4F&F9F&F0*&F7F&F
<F&F&" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%%aDDsG,8*&,**&\"\"%\"\"\")%
\"xG\"\"$F*!\"\"*(F)F*)F,\"\"&F*%\"aGF*F**(F)F*F2F*F,F*F**(F)F*)F2\"\"
#F*F+F*F.F*%\"yGF*F*F*F**&F6F*F+F*F**(F6F*)F,F6F*F2F*F.*(F6F*F0F*F2F*F
.*(F6F*F2F*)F,F)F*F.*(F6F*F2F*F,F*F.*(F6F*F5F*F+F*F**&F=F*F5F*F**$)F,
\"\"'F*F**&F5F*F:F*F*" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 56 "CC
 := abs(FF)*(1-x^2)^2;\nBB := abs(DD)-x*(1-a)*abs(EE);\n" }}{PARA 11 "
" 1 "" {XPPMATH 20 "6#>%#CCG*&-%$absG6#,(%\"aG\"\"\"*&\"\"#F+%\"cGF+F+
*&F*F+)F.F-F+F+F+),&F+F+*$)%\"xGF-F+!\"\"F-F+" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#>%#BBG,&-%$absG6#,(\"\"\"!\"\"*&%\"aGF*%\"cGF*F+*&)%\"x
G\"\"#F*,&F-F*F.F*F*F*F**(F1F*,&F*F*F-F+F*-F'6#,&F.F*F*F+F*F+" }}}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 15 "HH := CC/BB^2;\n" }}{PARA 
11 "" 1 "" {XPPMATH 20 "6#>%#HHG*(-%$absG6#,(%\"aG\"\"\"*&\"\"#F+%\"cG
F+F+*&F*F+)F.F-F+F+F+,&F+F+*$)%\"xGF-F+!\"\"F-,&-F'6#,(F+F5*&F*F+F.F+F
5*&F3F+,&F*F+F.F+F+F+F+*(F4F+,&F+F+F*F5F+-F'6#,&F.F+F+F5F+F5!\"#" }}}
{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 18 "Th
e parameters (a," }{XPPEDIT 18 0 "alpha;" "6#%&alphaG" }{TEXT -1 32 ")
 lie in the critical trapezoid " }{TEXT 260 1 "T" }{TEXT -1 44 " bound
ed on the left side and right side by " }{XPPEDIT 18 0 "l[1](alpha)" "
6#-&%\"lG6#\"\"\"6#%&alphaG" }{TEXT -1 5 " and " }{XPPEDIT 18 0 "l[2](
alpha);" "6#-&%\"lG6#\"\"#6#%&alphaG" }{TEXT -1 6 " .    " }}{PARA 0 "
" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 100 "We introduce a au
xiliary parameter t which varies between 0 and 1 (and eliminate the de
pendency of  " }{TEXT 261 1 "a" }{TEXT -1 11 " on alpha)." }}{PARA 0 "
" 0 "" {TEXT -1 0 "" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 27 "at :
= (l1 + (t)*(l2-l1)/1);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#atG,(*&
\"\"&!\"\"%&alphaG\"\"\"F*#F*F'F(*&%\"tGF*,&F*F**(\"\"$F*F'F(F)F*F(F*F
*" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 21 "HHy := subs(a=at,HH);
" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%$HHyG*(-%$absG6#,,*&\"\"&!\"\"%&
alphaG\"\"\"F.#F.F+F,*&%\"tGF.,&F.F.*(\"\"$F.F+F,F-F.F,F.F.*&\"\"#F.%
\"cGF.F.*&,(*&F+F,F-F.F.#F.F+F,F0F.F.)F7F6F.F.F.,&F.F.*$)%\"xGF6F.F,F6
,&-F'6#,(F.F,*&F9F.F7F.F,*&F?F.,**&F+F,F-F.F.#F.F+F,F0F.F7F.F.F.F.*(F@
F.,(#\"\"'F+F.*&F+F,F-F.F,F0F,F.-F'6#,&F7F.F.F,F.F,!\"#" }}}{EXCHG 
{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 39 "Graphical
 view for specific values of  " }{XPPEDIT 18 0 "alpha;" "6#%&alphaG" }
{TEXT -1 1 " " }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" 
{TEXT -1 35 "Note the output has been suppressed" }}{PARA 0 "" 0 "" 
{TEXT -1 2 "  " }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 119 "alpha :=
 1.0:\nplot3d(subs(c=x*(cos(theta)+I*sin(theta)),x=0.75*m,HHy),t=0..1,
theta=0..Pi,axes=boxed):\nalpha := 'alpha':" }}}{EXCHG {PARA 0 "" 0 "
" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 130 "The functions h1 and h
2 are the sharp upper bounds on HH for the restricted parameter cases \+
theta = 0 and theta = pi, respectively" }}{PARA 0 "" 0 "" {TEXT -1 0 "
" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 49 "h1p := ((alpha+1)*a + 1
)*(alpha+2)/(alpha+1+a)^2;" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%$h1pG*
(,&*&,&%&alphaG\"\"\"F*F*F*%\"aGF*F*F*F*F*,&F)F*\"\"#F*F*,(F)F*F*F*F+F
*!\"#" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 31 "h2p := (1 - a*(alp
ha+1))/alpha;" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%$h2pG*&,&\"\"\"F'*&
,&%&alphaGF'F'F'F'%\"aGF'!\"\"F'F*F," }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 21 "h1 := subs(a=l2,h1p);" }}{PARA 11 "" 1 "" {XPPMATH 
20 "6#>%#h1G*(,&*&,&%&alphaG\"\"\"F*F*F*,&#\"\"%\"\"&F**(\"\"#F*F.!\"
\"F)F*F1F*F*F*F*F*,&F)F*F0F*F*,&*(\"\"$F*F.F1F)F*F*#\"\"*F.F*!\"#" }}}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 21 "h2 := subs(a=l1,h2p);" }}
{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#h2G*&,&\"\"\"F'*&,&%&alphaGF'F'F'F'
,&*&\"\"&!\"\"F*F'F'#F'F-F.F'F.F'F*F." }}}{EXCHG {PARA 0 "" 0 "" 
{TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 123 "Rather than trying to sh
ow that HH is bounded above by the max\{h1,h2\} we identify an (single
) upper bound h3 for max\{h1,h2\}" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}
{PARA 0 "" 0 "" {TEXT -1 43 "We will show that HH is bounded above by \+
h3" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 70 "h3 := 1 - (4/5)*(alpha-1) + (13/10)*(alpha-1)^2 - (13
/10)*(alpha-1)^3;" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#h3G,*#\"\"*\"
\"&\"\"\"*(\"\"%F)F(!\"\"%&alphaGF)F,*(\"#8F)\"#5F,,&F-F)F)F,\"\"#F)*(
F/F)F0F,F1\"\"$F," }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 60 "plot([
