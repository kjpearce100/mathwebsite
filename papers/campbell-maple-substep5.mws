"" {TEXT -1 18 "We will replace in" }{TEXT 291 3 " f2" }{TEXT -1 15 " \+
the parameter " }{TEXT 290 1 "x" }{TEXT -1 5 " = m(" }{XPPEDIT 18 0 "a
lpha;" "6#%&alphaG" }{TEXT -1 28 ") by a rational lower bound " }
{TEXT 289 2 "xa" }{TEXT -1 20 "3 depending only on " }{XPPEDIT 18 0 "a
lpha;" "6#%&alphaG" }{TEXT -1 48 ".  We will then show the resulting f
