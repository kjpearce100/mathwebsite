1*Gr:qSXq*ei_k;Z_u(R55*H\"" }}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}
{PARA 0 "" 0 "" {TEXT -1 40 "By the above (Sturm sequence argument)  \+
" }{XPPEDIT 18 0 "(alpha+1-xa3)^2-alpha^2-2*alpha" "6#,(*$,(%&alphaG\"
\"\"F'F'%$xa3G!\"\"\"\"#F'*$F&F*F)*&F*F'F&F'F)" }{TEXT -1 27 "  has no
 zeros; therefore, " }{XPPEDIT 18 0 "(alpha+1-xa3)^2-alpha^2-2*alpha" 
"6#,(*$,(%&alphaG\"\"\"F'F'%$xa3G!\"\"\"\"#F'*$F&F*F)*&F*F'F&F'F)" }
{TEXT -1 18 " has constant sign" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}
{PARA 0 "" 0 "" {TEXT -1 19 "Since the value at " }{XPPEDIT 18 0 "alph
a" "6#%&alphaG" }{TEXT 298 1 " " }{TEXT -1 11 " = 6/5 of  " }{XPPEDIT 
18 0 "(alpha+1-xa3)^2-alpha^2-2*alpha" "6#,(*$,(%&alphaG\"\"\"F'F'%$xa
3G!\"\"\"\"#F'*$F&F*F)*&F*F'F&F'F)" }{TEXT -1 15 "  is positive, " }
{XPPEDIT 18 0 "(alpha+1-xa3)^2-alpha^2-2*alpha" "6#,(*$,(%&alphaG\"\"
\"F'F'%$xa3G!\"\"\"\"#F'*$F&F*F)*&F*F'F&F'F)" }{TEXT -1 16 "  is posit
ive.  " }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}}{EXCHG {PARA 0 "" 0 "" 
{TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 25 "Since the coefficient of \+
" }{TEXT 299 1 "x" }{TEXT -1 4 " in " }{TEXT 300 1 "f" }{TEXT -1 32 "2
 is positive, substitution of  " }{TEXT 301 2 "xa" }{TEXT -1 6 "3 for \+
" }{TEXT 302 1 "x" }{TEXT -1 4 " in " }{TEXT 303 1 "f" }{TEXT -1 25 "2
 creates a lower bound (" }{TEXT 304 1 "f" }{TEXT -1 1 "2" }{TEXT 305 
2 "xa" }{TEXT -1 7 "3) for " }{TEXT 306 1 "f" }{TEXT -1 2 "2." }}
{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 46 "We then a
pply a Sturm sequence calculation to " }{TEXT 307 1 "f" }{TEXT -1 1 "2
