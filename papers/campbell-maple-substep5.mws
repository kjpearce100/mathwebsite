e,  " }{TEXT 317 1 "f" }{TEXT -1 1 "2" }{TEXT 318 2 "xa" }{TEXT -1 15 
"3  is positive." }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}}{EXCHG {PARA 0 ">
 " 0 "" {MPLTEXT 1 0 13 "Digits := 10:" }}}{EXCHG {PARA 0 "" 0 "" 
{TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 21 "Second, the factor f1" }}
{PARA 0 "" 0 "" {TEXT -1 0 "" }}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" 
}}{PARA 0 "" 0 "" {TEXT -1 48 "We will specifically substitute into th
e factor " }{TEXT 319 1 "f" }{TEXT -1 27 "1 the proposed upper bound \+
" }{TEXT 320 1 "h" }{TEXT -1 22 "3 for the placeholder " }{TEXT 321 1 
"k" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 32 "f3 := normal(400*subs(k=h3,f1)):" }}}{EXCHG {PARA 0 "
> " 0 "" {MPLTEXT 1 0 62 "plot3d(subs(alpha=1.2,f3)/100000000,y=0..1,t
=0..1,axes=boxed):" }}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 
"" 0 "" {TEXT -1 27 "The range on the parameter " }{XPPEDIT 18 0 "alph
a;" "6#%&alphaG" }{TEXT -1 12 "  is   1 <= " }{XPPEDIT 18 0 "alpha;" "
6#%&alphaG" }{TEXT -1 10 "  < 1.65  " }}{PARA 0 "" 0 "" {TEXT -1 0 "" 
}}{PARA 0 "" 0 "" {TEXT -1 68 "For convenience in ensuing argumentm we
 will shift to the parameter " }{XPPEDIT 18 0 "beta = alpha+1;" "6#/%%
betaG,&%&alphaG\"\"\"F'F'" }{TEXT -1 10 " ,  0 <=  " }{XPPEDIT 18 0 "b
eta;" "6#%%betaG" }{TEXT -1 7 " < 0.65" }}{PARA 0 "" 0 "" {TEXT -1 2 "
  " }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 38 "f4 := subs(alpha=beta
+1,f3)/100000000:" }}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "
" 0 "" {TEXT -1 21 "We need to show that " }{TEXT 322 1 "f" }{TEXT -1 
43 "4 is non-negative to finish the argument.  " }{TEXT 323 1 "f" }
{TEXT -1 21 "4 is a polynomial in " }{XPPEDIT 18 0 "beta" "6#%%betaG" 
}{TEXT -1 36 ", y and t with rational coefficients" }}{PARA 0 "" 0 "" 
{TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 5 "where" }}{PARA 0 "" 0 "" 
{TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 12 "     0 <=   " }{XPPEDIT 
18 0 "beta;" "6#%%betaG" }{TEXT -1 28 "  < 0.65\n     0 <=   y  <= 1" 
}}{PARA 0 "" 0 "" {TEXT -1 20 "     0 <=   t   <= 1" }}{PARA 0 "" 0 "
" {TEXT -1 1 " " }}{PARA 0 "" 0 "" {TEXT -1 14 "The domain of " }
{TEXT 324 1 "f" }{TEXT -1 38 "4 lies in the first (positive) octant." 
}}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 57 "We note
, in particular, that the value at the origin is 0" }}{PARA 0 "" 0 "" 
{TEXT -1 0 "" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 24 "subs(beta=0
,y=0,t=0,f4);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#\"\"!" }}}{EXCHG 
{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 62 "We will a
pply an extentsion of Lemma 5.3 (B-3) to verify that " }{TEXT 325 1 "f
" }{TEXT -1 20 "4 > 0 on  (0,0.15)^3" }}{PARA 0 "" 0 "" {TEXT -1 0 "" 
}}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 64 
"First, we calculate the magnitude of each partial derivative of " }
