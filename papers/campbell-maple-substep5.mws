positive." }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 
68 "First, we give below an approximation to sqrt(3).  We then constru
ct" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 45 "   \+
  s3b:  a rational upper bound for sqrt(3)" }}{PARA 0 "" 0 "" {TEXT 
-1 45 "     s3a:  a rational lower bound for sqrt(3)" }}{PARA 0 "" 0 "
" {TEXT -1 0 "" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 220 "Digits :
= 60:\ns3 := round(1.732050807568877293527446341505872366943*10^40)/10
^40;\ns3b := round(1.732050807568877293527446341505872366950*10^40)/10
^40;\ns3a := round(1.732050807568877293527446341505872366940*10^40)/10
^40;\n" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%#s3G#\"IVpOse]TjWFNHx)ov!3
0K<\"I+++++++++++++++++++5" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#>%$s3bG#
\"GRtW<,$o#*[0(eax8:;5kM\"G++++++++++++++++++?" }}{PARA 11 "" 1 "" 
{XPPMATH 20 "6#>%$s3aG#\"GZ$=OHvqJsjnkQWy.a-m)\"G++++++++++++++++++]" 
}}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 24 
"The Taylor's expansion, " }{TEXT 294 3 "xa," }{TEXT -1 5 " of  " }
{TEXT 288 1 "x" }{TEXT -1 5 " = m(" }{XPPEDIT 18 0 "alpha;" "6#%&alpha
G" }{TEXT -1 65 ") is an alternating series with coefficients of the f
orm sqrt(3)*" }{XPPEDIT 18 0 "c[j];" "6#&%\"cG6#%\"jG" }{TEXT -1 9 "  \+
 where " }{XPPEDIT 18 0 "c[j];" "6#&%\"cG6#%\"jG" }{TEXT -1 14 "  is r
ational." }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 
6 "Where " }{XPPEDIT 18 0 "c[j];" "6#&%\"cG6#%\"jG" }{TEXT -1 74 "  is
 a positive rational we will replace sqrt(3) by the lower bound s3a.  \+
" }}{PARA 0 "" 0 "" {TEXT -1 6 "Where " }{XPPEDIT 18 0 "c[j];" "6#&%\"
cG6#%\"jG" }{TEXT -1 74 " is a negative rational we will replace sqrt(
3) by the upper bound s3b.   " }}{PARA 0 "" 0 "" {TEXT -1 1 " " }}
{PARA 0 "" 0 "" {TEXT -1 24 "The resulting function  " }{TEXT 293 2 "x
a" }{TEXT -1 92 "3 will be a polynomial in alpha with rational coeffic
ients which provides a lower bound for " }{TEXT 292 1 "x" }{TEXT -1 3 
" = " }{TEXT 295 1 "m" }{TEXT -1 1 "(" }{XPPEDIT 18 0 "alpha;" "6#%&al
phaG" }{TEXT -1 6 ")     " }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 93 "nn := 44:\nxa := convert((taylor(m,
alpha=1,nn)),polynom,alpha):\nxab := subs(alpha-1=beta,xa):\n" }}}
{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 222 "xa3 := 2-s3b + (1-2*s3b/3)*
(alpha-1):\nfor j from 2 to nn by 2 do xa3 := xa3 + subs(sqrt(3)=s3a,c
oeff(xab,beta,j))*(alpha-1)^j od:\nfor j from 3 to nn by 2 do xa3 := x
a3 + subs(sqrt(3)=s3b,coeff(xab,beta,j))*(alpha-1)^j  od:" }}}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 28 "plot([m,xa3],alpha=1..1.65):" }}}
{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 14 "To
 verify that" }}{PARA 0 "" 0 "" {TEXT -1 7 "       " }{TEXT 296 1 "m" 
}{TEXT -1 1 "(" }{XPPEDIT 18 0 "alpha;" "6#%&alphaG" }{TEXT -1 5 ")  =
 " }{XPPEDIT 18 0 "alpha+1-(alpha^2+2*alpha)^(1/2);" "6#,(%&alphaG\"\"
\"F%F%),&*$F$\"\"#F%*&F)F%F$F%F%*&F%F%F)!\"\"F," }{TEXT -1 4 "  > " }
{TEXT 297 2 "xa" }{TEXT -1 3 "3  " }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}
{PARA 0 "" 0 "" {TEXT -1 26 "we show equivalently that " }}{PARA 0 "" 
0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 5 "     " }{XPPEDIT 18 
0 "(alpha+1-xa3)^2-alpha^2-2*alpha;" "6#,(*$,(%&alphaG\"\"\"F'F'%$xa3G
!\"\"\"\"#F'*$F&F*F)*&F*F'F&F'F)" }{TEXT -1 4 " > 0" }}{PARA 0 "" 0 "
" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 41 "which is a rational pol
ynomial inequality" }}{PARA 0 "" 0 "" {TEXT -1 3 "   " }}}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 70 "ma := (alpha + 1 - xa3)^2 - alpha^2
 - 2*alpha:\nplot(ma,alpha=1..1.65):" }}}{EXCHG {PARA 0 "> " 0 "" 
{MPLTEXT 1 0 69 "ss := sturmseq(ma,alpha):\nsturm(ss,alpha,1,1.65);\ns
ubs(alpha=6/5,ma);" }}{PARA 11 "" 1 "" {XPPMATH 20 "6#\"\"!" }}{PARA 
12 "" 1 "" {XPPMATH 20 "6##\"_upLtDh=)=Dst/0'y#pZm^gEx?Hz9-C34`&3x%R#*
\\T^gFt!=3!ov+\")*3'zN)en&*3^Gbu#H+'f&=$\\U(**oB!H'QD2CGc-\"\"`w++++++
