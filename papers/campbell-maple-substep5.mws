46 "1 we will discover two (non-constant) factors:" }}{PARA 0 "" 0 "" 
{TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 28 "   first, a factor which \+
is " }{TEXT 282 11 "independent" }{TEXT -1 4 " of " }{TEXT 280 1 "x" }
}{PARA 0 "" 0 "" {TEXT -1 39 "   second, a factor which is linear in \+
" }{TEXT 281 2 "x " }{TEXT -1 21 " and depends only on " }{TEXT 283 1 
"x" }{TEXT -1 5 " and " }{XPPEDIT 18 0 "alpha;" "6#%&alphaG" }}{PARA 
0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 12 "We will let " }
{TEXT 284 1 "f" }{TEXT -1 44 "1 denote the first of these two factors \+
and " }{TEXT 285 1 "f" }{TEXT -1 41 "2 denote the second of these two \+
factors." }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 
64 "In separate arguments, we will show that each factor is positive" 
}}{PARA 0 "" 0 "" {TEXT -1 0 "" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 
